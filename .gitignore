node_modules/
dist/
*.log
.DS_Store
# Generated packs are inspectable artifacts; keep the showcase one tracked
# but ignore ad-hoc local compiles:
.ada/packs/tmp-*/

# scratch / preview artifacts
._*

# live compile progress — volatile per-run state, never committed (like .state.json)
.ada/packs/*/.compile-progress.json
.ada/packs/*/.compile-progress.json.tmp
.ada/packs/*/.compile-progress.jsonl

# agent worktrees — embedded git checkouts from Claude Code agent runs, never commit
.claude/worktrees/

# local credentials — the API key lives here, NEVER commit it (loaded by src/env.ts)
.env
.env.*
.ada/.env

# internal compiler state, contracts, residue, and PRIVATE strategy notes — NEVER publish
.compiler/
