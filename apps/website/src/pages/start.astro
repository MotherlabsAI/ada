---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="Install Ada — Get started with the intent compiler | Motherlabs"
  description="Install Ada in under a minute. Run your first elicitation session, compile your intent, and produce CLAUDE.md, agents, and hooks before Claude Code starts building."
>
  <Nav />

  <main>
    <section class="page-hero">
      <div class="container">
        <p class="eyebrow">Get Started</p>
        <h1>Up and running in minutes.</h1>
        <p class="hero-sub">
          Ada runs in your terminal. No account. No dashboard. Intent in, CLAUDE.md out.
        </p>
      </div>
    </section>

    <section class="section section--sym">
      <span class="sym-watermark sym-watermark--right" aria-hidden="true">◈</span>
      <div class="container container--narrow">

        <div class="step">
          <div class="step-header">
            <span class="step-num">01</span>
            <h2>Prerequisites</h2>
          </div>
          <ul class="prereq-list">
            <li>Node.js 18 or later — <a href="https://nodejs.org" target="_blank" rel="noopener noreferrer">nodejs.org</a></li>
            <li>pnpm — <code>npm install -g pnpm</code></li>
            <li>An Anthropic API key — <a href="https://console.anthropic.com" target="_blank" rel="noopener noreferrer">console.anthropic.com</a></li>
          </ul>
        </div>

        <div class="step">
          <div class="step-header">
            <span class="step-num">02</span>
            <h2>Install <span class="early-tag">early access</span></h2>
          </div>
          <p class="step-note">
            Ada is in early access — clone and build locally:
          </p>
          <div class="code-block">
            <div class="code-lang">bash</div>
            <pre><code>git clone https://github.com/alexrozex/ada
cd ada && pnpm install && pnpm build</code></pre>
            <button class="copy-btn" data-copy="git clone https://github.com/alexrozex/ada &amp;&amp; cd ada &amp;&amp; pnpm install &amp;&amp; pnpm build" aria-label="Copy command">
              Copy
            </button>
          </div>
          <p class="step-note">
            npm package coming. <a href="https://github.com/alexrozex/ada" target="_blank" rel="noopener noreferrer">Star on GitHub</a> for updates.
          </p>
          <p class="step-note">Then set your API key:</p>
          <div class="code-block">
            <div class="code-lang">bash</div>
            <pre><code>ada config set-key --env ANTHROPIC_API_KEY</code></pre>
            <button class="copy-btn" data-copy="ada config set-key --env ANTHROPIC_API_KEY" aria-label="Copy command">
              Copy
            </button>
          </div>
        </div>

        <div class="step">
          <div class="step-header">
            <span class="step-num">03</span>
            <h2>Run Ada</h2>
          </div>
          <p class="step-note">In your project directory:</p>
          <div class="code-block">
            <div class="code-lang">bash</div>
            <pre><code>ada compile</code></pre>
            <button class="copy-btn" data-copy="ada compile" aria-label="Copy command">
              Copy
            </button>
          </div>
          <p class="step-note">
            Ada opens an elicitation session. It will ask the minimum set of questions
            needed to resolve blocking unknowns. Answer at your level of abstraction —
            not technical, semantic. What should the system do? What should it not?
          </p>
          <p class="step-note">
            When elicitation is complete, Ada compiles the canonical semantic model and
            hands it to Claude Code. The governed blueprint is in <code>.ada/</code>.
          </p>
        </div>

        <div class="step">
          <div class="step-header">
            <span class="step-num">04</span>
            <h2>What to expect</h2>
          </div>
          <div class="expect-list">
            <div class="expect-item">
              <span class="expect-marker"></span>
              <p>Ada streams its reasoning in real time — you can see it thinking, not just a spinner.</p>
            </div>
            <div class="expect-item">
              <span class="expect-marker"></span>
              <p>Elicitation asks 3–7 questions depending on intent complexity. No technical questions. Semantic ones.</p>
            </div>
            <div class="expect-item">
              <span class="expect-marker"></span>
              <p>Compilation produces artifacts in <code>.ada/</code> — intent graph, entity map, process flow, blueprint.</p>
            </div>
            <div class="expect-item">
              <span class="expect-marker"></span>
              <p>Claude Code spawns with the governed blueprint. It builds against Ada's decisions, not against memory.</p>
            </div>
          </div>
        </div>

        <div class="next-steps">
          <h2>What's next</h2>
          <p>
            Read the Ada architecture on the <a href="/ada">Ada page</a> to understand how
            the pipeline works. The source is on
            <a href="https://github.com/alexrozex/ada" target="_blank" rel="noopener noreferrer">GitHub</a>.
          </p>
        </div>

      </div>
    </section>
  </main>

  <Footer />
</Layout>

<script>
  document.querySelectorAll<HTMLButtonElement>('.copy-btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      const text = btn.dataset.copy ?? '';
      navigator.clipboard.writeText(text).then(() => {
        const original = btn.textContent;
        btn.textContent = 'Copied';
        setTimeout(() => {
          btn.textContent = original;
        }, 1500);
      });
    });
  });
</script>

<style>
  .container {
    max-width: 72rem;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .container--narrow {
    max-width: 44rem;
  }

  .page-hero {
    padding: 6rem 0 5rem;
    border-bottom: 1px solid var(--color-border);
  }

  .eyebrow {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin: 0 0 1rem;
  }

  .page-hero h1 {
    font-family: var(--font-serif);
    font-size: clamp(2rem, 4.5vw, 3rem);
    font-weight: 400;
    margin: 0 0 1.25rem;
    max-width: 26rem;
  }

  .early-tag {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    font-weight: 400;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-accent);
    border: 1px solid var(--color-accent);
    padding: 0.15rem 0.4rem;
    vertical-align: middle;
    margin-left: 0.5rem;
    border-radius: 5px;
  }

  .hero-sub {
    font-size: 1.0625rem;
    color: var(--color-text-muted);
    max-width: 36rem;
    margin: 0;
    line-height: 1.65;
  }

  .section {
    padding: 5rem 0;
  }

  /* ── Symbol watermark ── */
  .section--sym { position: relative; overflow: hidden; }
  .sym-watermark {
    position: absolute;
    font-family: var(--font-mono);
    font-size: clamp(14rem, 28vw, 22rem);
    line-height: 1;
    color: var(--color-text);
    opacity: 0.028;
    user-select: none;
    pointer-events: none;
    top: 50%;
    left: -3rem;
    transform: translateY(-50%);
  }
  .sym-watermark--right { left: auto; right: -3rem; }

  .step {
    padding: 3rem 0;
    border-bottom: 1px solid var(--color-border);
  }

  .step:last-of-type {
    border-bottom: none;
  }

  .step-header {
    display: flex;
    align-items: baseline;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }

  .step-num {
    font-size: 0.7rem;
    font-weight: 700;
    font-family: var(--font-mono);
    color: var(--color-accent);
    letter-spacing: 0.05em;
    flex-shrink: 0;
  }

  .step-header h2 {
    font-size: 1.125rem;
    font-weight: 700;
    margin: 0;
  }

  .prereq-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .prereq-list li {
    font-size: 0.9375rem;
    color: var(--color-text-muted);
    display: flex;
    gap: 0.5rem;
    align-items: baseline;
  }

  .prereq-list li::before {
    content: '—';
    color: var(--color-border);
    flex-shrink: 0;
  }

  .prereq-list code {
    font-size: 0.875rem;
    color: var(--color-accent);
    background-color: var(--color-surface);
    padding: 0.1rem 0.35rem;
    border-radius: 0.25rem;
    border: 1px solid var(--color-border);
  }

  .prereq-list a {
    color: var(--color-accent);
  }

  .code-block {
    position: relative;
    margin-bottom: 1rem;
  }

  .code-lang {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    padding: 0.5rem 1.25rem 0;
    background-color: var(--color-surface);
    border: 1px solid var(--color-border);
    border-bottom: none;
    border-radius: 0.5rem 0.5rem 0 0;
  }

  .code-block pre {
    border-radius: 0 0 0.5rem 0.5rem;
    margin: 0;
    font-size: 0.9375rem;
  }

  .code-block code {
    color: var(--color-text);
  }

  .copy-btn {
    position: absolute;
    top: 2.25rem;
    right: 0.75rem;
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--color-text-muted);
    background: var(--color-surface-raised);
    border: 1px solid var(--color-border);
    border-radius: 6px;
    padding: 0.25rem 0.5rem;
    cursor: pointer;
    transition: color 0.15s;
  }

  .copy-btn:hover {
    color: var(--color-text);
  }

  .step-note {
    font-family: var(--font-mono);
    font-size: 0.875rem;
    color: var(--color-text-muted);
    margin: 0 0 1rem;
    line-height: 1.7;
  }

  .step-note code {
    font-size: 0.875rem;
    color: var(--color-accent);
  }

  .expect-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-top: 0.5rem;
  }

  .expect-item {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
  }

  .expect-marker {
    flex-shrink: 0;
    width: 5px;
    height: 5px;
    background-color: var(--color-accent);
    border-radius: 50%;
    margin-top: 0.6em;
  }

  .expect-item p {
    font-family: var(--font-mono);
    font-size: 0.875rem;
    color: var(--color-text-muted);
    margin: 0;
    line-height: 1.7;
  }

  .expect-item code {
    font-size: 0.875rem;
    color: var(--color-accent);
  }

  .next-steps {
    padding-top: 3rem;
    border-top: 1px solid var(--color-border);
  }

  .next-steps h2 {
    font-size: 1.125rem;
    font-weight: 700;
    margin: 0 0 0.75rem;
  }

  .next-steps p {
    font-size: 0.9375rem;
    color: var(--color-text-muted);
    margin: 0;
    line-height: 1.65;
  }

  @media (max-width: 640px) {
    .page-hero {
      padding: 4rem 0 3.5rem;
    }
  }
</style>
