---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const softwareSchema = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'Ada',
  applicationCategory: 'DeveloperApplication',
  operatingSystem: 'macOS, Linux, Windows',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
  description: 'Ada structures your intent before Claude Code starts — producing CLAUDE.md, agents, and hooks that Claude Code reads every session. Requirements elicitation before building begins.',
  url: 'https://motherlabs.ai',
  publisher: { '@type': 'Organization', name: 'Motherlabs', url: 'https://motherlabs.ai' },
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'What is Ada?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Ada closes the intent gap. You describe what you want to build — in plain language, no technical vocabulary required. Ada runs structured elicitation to surface blocking unknowns, then compiles your intent into CLAUDE.md, agent files, and hook files that Claude Code reads every session. It runs before development, not during.',
      },
    },
    {
      '@type': 'Question',
      name: 'How is Ada different from MEMORY.md or Claude Code auto-memory?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: "Claude Code's auto-memory records what it observed as it worked — it is retrospective. Ada records what you intend before it starts — it is prospective. One captures drift after it happens. The other prevents it before building begins. They are not the same thing.",
      },
    },
    {
      '@type': 'Question',
      name: 'What does Ada produce?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Ada produces three artifacts: CLAUDE.md (the intent file Claude Code reads on every message turn), agents/ (specialized agent files scoped to bounded contexts), and hooks/ (pre-tool guards that enforce constraints at every tool call boundary). These are plain files you can read and verify before any build starts.',
      },
    },
    {
      '@type': 'Question',
      name: 'What is the intent gap?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'The intent gap is the structural distance between informal natural language requirements and the precise program behavior that gets built. Named in Microsoft Research (2026) as a grand challenge for reliable AI-assisted development. Ada closes it by formalizing intent into CLAUDE.md, agent files, and hook files before Claude Code starts.',
      },
    },
  ],
};
---

<Layout
  title="Ada — Close the intent gap before Claude Code starts | Motherlabs"
  description="Ada structures your intent before Claude Code starts. Requirements elicitation that produces CLAUDE.md, agents, and hooks — less distance between what you mean and what gets built."
  schemas={[softwareSchema, faqSchema]}
>
  <Nav />

  <main>

    <!-- ─── HERO ─────────────────────────────────────────────────────────── -->
    <section class="hero">
      <div class="hero-image-wrap" aria-hidden="true">
        <img src="/intent-notes.jpg" alt="" class="hero-image" loading="eager" decoding="async" />
      </div>
      <div class="container hero-content">
        <h1 class="hero-headline">
          Between what you mean<br />and what gets built,<br />something gets lost.
        </h1>
        <p class="hero-sub">
          Not because AI isn't capable.<br />
          Because intent was never structured before building started.
        </p>
        <div class="hero-actions">
          <a href="/start" class="btn-primary">Get started</a>
          <a href="/ada" class="btn-ghost">What is Ada? &rarr;</a>
        </div>
      </div>
    </section>

    <!-- ─── ADA CLI DEMO ──────────────────────────────────────────────────── -->
    <hr class="divider" />
    <section class="demo-section">
      <div class="container">
        <div class="demo-wrap">

          <!-- Compile block -->
          <div class="compile-block" aria-label="Ada compile output">
            <div class="compile-prompt">
              <span class="prompt-char">$</span>
              <span class="prompt-cmd">ada compile</span>
            </div>
            <div class="compile-stages">
              <div class="stage-row">
                <span class="stage-glyph stage-glyph--done">◆</span>
                <span class="stage-label">CTX</span>
                <span class="stage-desc">codebase context</span>
              </div>
              <div class="stage-row">
                <span class="stage-glyph stage-glyph--done">◆</span>
                <span class="stage-label">INT</span>
                <span class="stage-desc">intent graph</span>
              </div>
              <div class="stage-row">
                <span class="stage-glyph stage-glyph--done">◆</span>
                <span class="stage-label">PER</span>
                <span class="stage-desc">persona mapping</span>
              </div>
              <div class="stage-row">
                <span class="stage-glyph stage-glyph--done">◆</span>
                <span class="stage-label">ENT</span>
                <span class="stage-desc">entity extraction</span>
              </div>
              <div class="stage-row">
                <span class="stage-glyph stage-glyph--done">◆</span>
                <span class="stage-label">PRO</span>
                <span class="stage-desc">process synthesis</span>
              </div>
              <div class="stage-row">
                <span class="stage-glyph stage-glyph--done">◆</span>
                <span class="stage-label">SYN</span>
                <span class="stage-desc">synthesis</span>
              </div>
              <div class="stage-row stage-row--gov">
                <span class="stage-glyph stage-glyph--gov">◈</span>
                <span class="stage-label">GOV</span>
                <span class="stage-desc stage-approved">approved &nbsp; 0.94</span>
              </div>
            </div>
            <div class="compile-output">
              <div class="output-row output-row--claude">
                <span class="output-file">CLAUDE.md</span>
                <span class="output-action">written</span>
              </div>
              <div class="output-row output-row--agents">
                <span class="output-file">agents/</span>
                <span class="output-action">8 files written</span>
              </div>
              <div class="output-row output-row--hooks">
                <span class="output-file">hooks/</span>
                <span class="output-action">pre-tool guards written</span>
              </div>
            </div>
          </div>

          <!-- Callout annotations -->
          <div class="callouts">
            <div class="callout callout--gov">
              <div class="callout-dot"></div>
              <div class="callout-body">
                <span class="callout-label">GOV — approved 0.94</span>
                <p class="callout-text">Semantic coherence validated. The Governor scores your intent against the compiled blueprint before writing any files.</p>
              </div>
            </div>
            <div class="callout callout--claude">
              <div class="callout-dot"></div>
              <div class="callout-body">
                <span class="callout-label">CLAUDE.md</span>
                <p class="callout-text">Injected into every Claude Code context window, every session. Not a one-time setup — a persistent intent anchor.</p>
              </div>
            </div>
            <div class="callout callout--hooks">
              <div class="callout-dot"></div>
              <div class="callout-body">
                <span class="callout-label">hooks/</span>
                <p class="callout-text">Pre-tool guards that enforce your constraints at every tool call boundary. Before Claude Code acts, not after.</p>
              </div>
            </div>
          </div>

        </div>
      </div>
    </section>

    <!-- ─── ESSENTIAL INFO ───────────────────────────────────────────────── -->
    <hr class="divider" />
    <section class="essential-section">
      <div class="container container--narrow">

        <div class="output-list">
          <div class="output-item">
            <code class="out-file">CLAUDE.md</code>
            <span class="out-desc">The intent file. Claude Code reads this on every message turn — what the system is, what it is not, what constraints apply.</span>
          </div>
          <div class="output-item">
            <code class="out-file">agents/</code>
            <span class="out-desc">Specialist agents scoped to bounded contexts. Each knows its domain and its constraints.</span>
          </div>
          <div class="output-item">
            <code class="out-file">hooks/</code>
            <span class="out-desc">Pre-tool guards. Your intent, enforced at the boundary where decisions are made.</span>
          </div>
        </div>

        <div class="essential-cta">
          <div class="install-block">
            <span class="install-prompt">$</span>
            <code class="install-cmd">ada compile</code>
          </div>
          <div class="essential-links">
            <a href="/start" class="btn-primary">Get started</a>
            <a href="/ada" class="btn-ghost">Read about Ada &rarr;</a>
          </div>
        </div>

      </div>
    </section>

  </main>

  <Footer />
</Layout>

<style>
  /* ── Layout ──────────────────────────────────────────────────────────── */
  .container {
    max-width: 72rem;
    margin: 0 auto;
    padding: 0 clamp(1.5rem, 5vw, 4rem);
  }

  .container--narrow {
    max-width: 44rem;
  }

  .divider {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: 0;
  }

  /* ── Hero ────────────────────────────────────────────────────────────── */
  .hero {
    position: relative;
    min-height: 88vh;
    display: flex;
    align-items: center;
    overflow: hidden;
  }

  .hero-image-wrap {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 25%;
    opacity: 0.09;
    display: block;
  }

  /* Light mode: less opacity since image is bright */
  @media (prefers-color-scheme: light) {
    .hero-image { opacity: 0.06; }
  }
  [data-theme="light"] .hero-image { opacity: 0.06; }
  [data-theme="dark"] .hero-image { opacity: 0.09; }

  .hero-content {
    position: relative;
    z-index: 1;
    padding-top: 6rem;
    padding-bottom: 6rem;
  }

  .hero-headline {
    font-family: var(--font-serif);
    font-size: clamp(2.5rem, 5.5vw, 4.25rem);
    font-weight: 400;
    line-height: 1.08;
    letter-spacing: -0.015em;
    color: var(--color-text);
    margin: 0 0 1.5rem;
    max-width: 18ch;
  }

  .hero-sub {
    font-size: 1.0625rem;
    color: var(--color-text-muted);
    line-height: 1.75;
    margin: 0 0 2.75rem;
    max-width: 36rem;
  }

  .hero-actions {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    flex-wrap: wrap;
  }

  /* Buttons */
  .btn-primary {
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--color-bg);
    background-color: var(--color-accent);
    padding: 0.7rem 1.5rem;
    border-radius: 8px;
    transition: background-color 0.12s ease;
    display: inline-block;
  }

  .btn-primary:hover {
    background-color: var(--color-accent-hover);
    color: var(--color-bg);
  }

  .btn-ghost {
    font-size: 0.9375rem;
    color: var(--color-text-muted);
    transition: color 0.12s ease;
  }

  .btn-ghost:hover {
    color: var(--color-text);
  }

  /* ── Demo section ────────────────────────────────────────────────────── */
  .demo-section {
    padding: 5rem 0;
  }

  .demo-wrap {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 4rem;
    align-items: start;
  }

  /* Compile block */
  .compile-block {
    font-family: var(--font-mono);
    font-size: 0.875rem;
    line-height: 1.6;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    padding: 1.5rem 1.75rem;
    display: inline-flex;
    flex-direction: column;
    gap: 0;
    min-width: 22rem;
  }

  .compile-prompt {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 1.25rem;
    opacity: 0;
    animation: fade-in-up 180ms ease forwards;
    animation-delay: 80ms;
  }

  .prompt-char { color: var(--color-text-dim); }
  .prompt-cmd  { color: var(--color-text-muted); }

  .compile-stages {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    margin-bottom: 1.25rem;
  }

  .stage-row {
    display: grid;
    grid-template-columns: 1rem 2.5rem 1fr;
    align-items: center;
    gap: 0.5rem;
    padding: 0.1rem 0;
    opacity: 0;
    animation: fade-in-up 180ms ease forwards;
  }

  .stage-row--gov {
    margin-top: 0.125rem;
  }

  .stage-row:nth-child(1) { animation-delay: 200ms; }
  .stage-row:nth-child(2) { animation-delay: 310ms; }
  .stage-row:nth-child(3) { animation-delay: 420ms; }
  .stage-row:nth-child(4) { animation-delay: 530ms; }
  .stage-row:nth-child(5) { animation-delay: 640ms; }
  .stage-row:nth-child(6) { animation-delay: 750ms; }
  .stage-row:nth-child(7) { animation-delay: 860ms; }

  .stage-glyph      { font-size: 0.65rem; line-height: 1; }
  .stage-glyph--done { color: var(--color-text-dim); }
  .stage-glyph--gov  { color: var(--color-accent); }
  .stage-label       { color: var(--color-text-dim); letter-spacing: 0.04em; font-size: 0.8rem; }
  .stage-desc        { color: var(--color-text-muted); font-size: 0.8125rem; }
  .stage-approved    { color: var(--color-accent); font-weight: 500; }

  .compile-output {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    padding-top: 1rem;
    border-top: 1px solid var(--color-border);
  }

  .output-row {
    display: grid;
    grid-template-columns: 9rem 1fr;
    gap: 1rem;
    opacity: 0;
    animation: fade-in-up 180ms ease forwards;
  }

  .output-row:nth-child(1) { animation-delay: 1020ms; }
  .output-row:nth-child(2) { animation-delay: 1100ms; }
  .output-row:nth-child(3) { animation-delay: 1180ms; }

  .output-file   { color: var(--color-text); font-weight: 500; }
  .output-action { color: var(--color-text-dim); }

  /* Callouts */
  .callouts {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    padding-top: 0.5rem;
  }

  .callout {
    display: flex;
    align-items: flex-start;
    gap: 0.875rem;
  }

  .callout-dot {
    flex-shrink: 0;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background-color: var(--color-accent);
    margin-top: 0.45em;
  }

  .callout-body {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .callout-label {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--color-text);
    letter-spacing: 0.02em;
  }

  .callout-text {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    line-height: 1.65;
    margin: 0;
  }

  /* ── Essential info ──────────────────────────────────────────────────── */
  .essential-section {
    padding: 5rem 0 6rem;
  }

  .output-list {
    display: flex;
    flex-direction: column;
    margin-bottom: 3.5rem;
  }

  .output-item {
    display: grid;
    grid-template-columns: 8rem 1fr;
    gap: 1.5rem;
    padding: 1.125rem 0;
    border-top: 1px solid var(--color-border);
    align-items: baseline;
  }

  .output-item:last-child {
    border-bottom: 1px solid var(--color-border);
  }

  .out-file {
    font-family: var(--font-mono);
    font-size: 0.875rem;
    color: var(--color-text);
    font-weight: 500;
    background: none;
    padding: 0;
  }

  .out-desc {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    line-height: 1.65;
  }

  .essential-cta {
    padding-top: 2.5rem;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .install-block {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-family: var(--font-mono);
  }

  .install-prompt {
    color: var(--color-text-dim);
    font-size: 1rem;
    flex-shrink: 0;
  }

  .install-cmd {
    font-family: var(--font-mono);
    font-size: clamp(1rem, 2.5vw, 1.25rem);
    color: var(--color-accent);
    background: none;
    padding: 0;
    letter-spacing: -0.01em;
  }

  .essential-links {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    flex-wrap: wrap;
  }

  /* ── Mobile ──────────────────────────────────────────────────────────── */
  @media (max-width: 768px) {
    .demo-wrap {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }

    .compile-block {
      min-width: 0;
      width: 100%;
    }
  }

  @media (max-width: 640px) {
    .hero {
      min-height: 75vh;
    }

    .hero-headline {
      font-size: 2.25rem;
    }

    .output-item {
      grid-template-columns: 1fr;
      gap: 0.375rem;
    }
  }

  /* Reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .compile-prompt,
    .stage-row,
    .output-row { animation: none; opacity: 1; }
  }
</style>

<script>
  // Scroll-triggered entrance for below-fold sections
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.08 }
  );

  document.querySelectorAll('.animate-in').forEach((el) => observer.observe(el));
</script>
