---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const softwareSchema = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'Ada',
  applicationCategory: 'DeveloperApplication',
  operatingSystem: 'macOS, Linux, Windows',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
  description: 'Ada structures your intent before Claude Code starts. A 7-stage semantic compiler that produces CLAUDE.md, agents/, and hooks/ — the governed context layer your AI builds against.',
  url: 'https://motherlabs.ai',
  publisher: { '@type': 'Organization', name: 'Motherlabs', url: 'https://motherlabs.ai' },
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'What is Ada?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Ada is a semantic compiler for software intent. You describe what you want to build, Ada asks clarifying questions, then compiles a governed context layer — CLAUDE.md, agent files, and hook files — that Claude Code builds against. It runs before development, not during.',
      },
    },
    {
      '@type': 'Question',
      name: 'How is Ada different from MEMORY.md or Claude Code auto-memory?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: "Claude Code's auto-memory records what it observed as it worked — it is retrospective. Ada records what you intend before it starts — it is prospective. One captures drift after it happens. The other prevents it before building begins. They are not the same thing.",
      },
    },
    {
      '@type': 'Question',
      name: 'What does Ada produce?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Ada produces three artifacts: CLAUDE.md (the intent file Claude Code reads on every message turn), agents/ (specialized agent files scoped to bounded contexts), and hooks/ (pre-tool guards that enforce constraints at every tool call boundary). These are plain files you can read and verify before any build starts.',
      },
    },
    {
      '@type': 'Question',
      name: 'What is the intent gap?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'The intent gap is the structural distance between informal natural language requirements and the precise program behavior that gets built. Documented in Microsoft Research (2026), the gap exists because informal intent is never formalized before building starts. Ada closes this gap by compiling intent into governed artifacts before Claude Code touches code.',
      },
    },
  ],
};
---

<Layout
  title="Ada — Semantic intent compiler for Claude Code | Motherlabs"
  description="Ada structures your intent before Claude Code starts. A 7-stage compiler that produces CLAUDE.md, agents, and hooks — less distance between what you mean and what gets built."
  schemas={[softwareSchema, faqSchema]}
>
  <Nav />

  <main>

    <!-- ─── HERO ─────────────────────────────────────────────────────────── -->
    <section class="hero">
      <div class="container">

        <!-- Identity mark -->
        <span class="hero-diamond" aria-hidden="true">◈</span>

        <!-- Terminal compile block — answers "what is this?" before headline -->
        <div class="compile-block" aria-label="Ada compile output">
          <div class="compile-prompt">
            <span class="prompt-char">$</span>
            <span class="prompt-cmd">ada compile</span>
          </div>
          <div class="compile-stages">
            <div class="stage-row">
              <span class="stage-glyph stage-glyph--done">◆</span>
              <span class="stage-label">CTX</span>
              <span class="stage-desc">codebase context</span>
            </div>
            <div class="stage-row">
              <span class="stage-glyph stage-glyph--done">◆</span>
              <span class="stage-label">INT</span>
              <span class="stage-desc">intent graph</span>
            </div>
            <div class="stage-row">
              <span class="stage-glyph stage-glyph--done">◆</span>
              <span class="stage-label">PER</span>
              <span class="stage-desc">persona mapping</span>
            </div>
            <div class="stage-row">
              <span class="stage-glyph stage-glyph--done">◆</span>
              <span class="stage-label">ENT</span>
              <span class="stage-desc">entity extraction</span>
            </div>
            <div class="stage-row">
              <span class="stage-glyph stage-glyph--done">◆</span>
              <span class="stage-label">PRO</span>
              <span class="stage-desc">process synthesis</span>
            </div>
            <div class="stage-row">
              <span class="stage-glyph stage-glyph--done">◆</span>
              <span class="stage-label">SYN</span>
              <span class="stage-desc">synthesis</span>
            </div>
            <div class="stage-row">
              <span class="stage-glyph stage-glyph--gov">◈</span>
              <span class="stage-label">GOV</span>
              <span class="stage-desc stage-approved">approved &nbsp; 0.94</span>
            </div>
          </div>
          <div class="compile-output">
            <div class="output-row">
              <span class="output-file">CLAUDE.md</span>
              <span class="output-action">written</span>
            </div>
            <div class="output-row">
              <span class="output-file">agents/</span>
              <span class="output-action">8 files written</span>
            </div>
            <div class="output-row">
              <span class="output-file">hooks/</span>
              <span class="output-action">247 files written</span>
            </div>
          </div>
        </div>

        <!-- Headline and CTA -->
        <h1 class="hero-headline">
          Between what you mean<br />and what gets built,<br />something gets lost.
        </h1>
        <p class="hero-sub">
          Not because AI isn't capable.<br />
          Because intent was never structured before building started.
        </p>
        <div class="hero-actions">
          <a href="/start" class="btn-primary">Get started</a>
          <a href="/ada" class="btn-ghost">What is Ada? &rarr;</a>
        </div>

      </div>
    </section>

    <!-- ─── RECOGNITION ──────────────────────────────────────────────────── -->
    <hr class="divider" />
    <section class="section animate-in">
      <div class="container container--prose">
        <p class="hook">
          You describe something to Claude Code. It builds.
          The next session, it builds from where it thinks it left off —
          which isn't quite where you left off.
          By the time the drift is visible, rewinding is harder than starting over.
        </p>
        <p>
          The gap is not a prompt problem. It is a structural one.
          Your intent was never written down in a form that persists.
          It lived in a chat window. The chat window closed.
        </p>
        <p>
          Most tools address this after the fact — better prompts,
          auto-memory, clearer mid-build instructions. These help.
          They don't fix the root.
        </p>
      </div>
    </section>

    <!-- ─── EDITORIAL IMAGE ──────────────────────────────────────────────── -->
    <div class="editorial-image animate-in">
      <img
        src="/intent-notes.jpg"
        alt="A person standing in a bright studio, contemplating hundreds of handwritten notes suspended in space — the visual metaphor for unstructured intent."
        class="editorial-img"
        loading="lazy"
        decoding="async"
      />
      <p class="editorial-caption">
        Unstructured intent, suspended. Ada compiles it into something that governs.
      </p>
    </div>

    <!-- ─── SEPARATION (the differentiator) ──────────────────────────────── -->
    <hr class="divider" />
    <section class="section animate-in">
      <div class="container container--prose">
        <div class="distinction">
          <p class="distinction-line">
            Claude Code's auto-memory records what it observed as it worked.
          </p>
          <p class="distinction-line">
            Ada records what you intend before it starts.
          </p>
          <p class="distinction-caption">
            One is retrospective. One is prospective. They are not the same thing.
          </p>
        </div>
      </div>
    </section>

    <!-- ─── MECHANISM ────────────────────────────────────────────────────── -->
    <hr class="divider" />
    <section class="section animate-in">
      <div class="container container--prose">
        <p class="lead">Ada is the step before.</p>
        <p>
          You describe what you want to build — at whatever level you think in.
          Ada asks you the questions that surface what you actually mean.
          Not framework questions. Not library questions.
          Questions about what the thing should do and be.
        </p>
        <p>
          You answer. Ada compiles. The files land on disk.
        </p>
        <p class="result-statement">
          Less distance between what you described and what gets built.<br />
          Not zero. Less.
        </p>
      </div>
    </section>

    <!-- ─── ARTIFACT ─────────────────────────────────────────────────────── -->
    <hr class="divider" />
    <section class="section animate-in">
      <div class="container container--prose">
        <p class="section-label">What Ada produces</p>

        <!-- File listing — ls-style, not a card grid -->
        <div class="file-listing">
          <div class="file-row">
            <code class="file-name">CLAUDE.md</code>
            <span class="file-desc">Claude Code reads this on every message turn — not just at session start. What the project is. What it is not. What constraints apply. Injected into every context window.</span>
          </div>
          <div class="file-row">
            <code class="file-name">agents/</code>
            <span class="file-desc">Specialized agents scoped to bounded contexts. Each knows its domain and its constraints.</span>
          </div>
          <div class="file-row">
            <code class="file-name">hooks/</code>
            <span class="file-desc">247 pre-tool guards that run before Claude Code takes actions. The constraints from your intent, enforced at the boundary where decisions are made.</span>
          </div>
        </div>

        <!-- CLAUDE.md excerpt — show a real one, not just describe it -->
        <div class="excerpt-block" aria-label="Example CLAUDE.md excerpt">
          <div class="excerpt-label">CLAUDE.md &mdash; excerpt</div>
          <div class="excerpt-content">
            <div class="excerpt-line excerpt-heading"># Analytics Dashboard</div>
            <div class="excerpt-line excerpt-blank"></div>
            <div class="excerpt-line excerpt-key">What this project is:</div>
            <div class="excerpt-line excerpt-val">A self-hosted web analytics dashboard. Privacy-first.</div>
            <div class="excerpt-line excerpt-val">No cookies. Tracks pageviews, unique visitors, referrers.</div>
            <div class="excerpt-line excerpt-blank"></div>
            <div class="excerpt-line excerpt-key">What it is not:</div>
            <div class="excerpt-line excerpt-val">Not a marketing platform. Not a cookie-based tracker.</div>
            <div class="excerpt-line excerpt-blank"></div>
            <div class="excerpt-line excerpt-key">Constraints that apply:</div>
            <div class="excerpt-line excerpt-val">No third-party analytics. Single-tenant deployment.</div>
            <div class="excerpt-line excerpt-val">Data stays on the server. No external egress.</div>
          </div>
        </div>

        <p class="file-note">
          Plain files. You read them before handing to Claude Code.
          If they match what you meant: proceed.
          If not: run Ada again with the correction.
        </p>
      </div>
    </section>

    <!-- ─── INVITATION ───────────────────────────────────────────────────── -->
    <hr class="divider" />
    <section class="section section--invite animate-in">
      <div class="container container--prose">
        <div class="install-block">
          <span class="install-prompt">$</span>
          <code class="install-cmd">git clone https://github.com/alexrozex/ada</code>
        </div>
        <p class="install-note">Early access — npm package coming soon.</p>
        <p class="trust-signal">
          Built by one person. ~400 iterations since late 2024.
        </p>
        <a href="/ada" class="btn-ghost invite-link">Read about Ada &rarr;</a>
      </div>
    </section>

  </main>

  <Footer />
</Layout>

<style>
  /* ── Layout ──────────────────────────────────────────────────────────── */
  .container {
    max-width: 72rem;
    margin: 0 auto;
    padding: 0 clamp(1.5rem, 5vw, 4rem);
  }

  .container--prose {
    max-width: 42rem;
  }

  /* ── Dividers ────────────────────────────────────────────────────────── */
  .divider {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: 0;
  }

  /* ── Hero ────────────────────────────────────────────────────────────── */
  .hero {
    padding: 5rem 0 4rem;
  }

  /* Identity mark */
  .hero-diamond {
    font-family: var(--font-mono);
    font-size: 1rem;
    color: var(--color-accent);
    display: block;
    margin-bottom: 2.25rem;
    animation: diamond-breathe 3s ease-in-out infinite;
  }

  /* Compile block */
  .compile-block {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    line-height: 1.6;
    margin-bottom: 3.5rem;
    display: inline-flex;
    flex-direction: column;
    gap: 0;
  }

  .compile-prompt {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 1rem;
    opacity: 0;
    animation: fade-in-up 180ms ease forwards;
    animation-delay: 80ms;
  }

  .prompt-char {
    color: var(--color-text-dim);
  }

  .prompt-cmd {
    color: var(--color-text-muted);
  }

  .compile-stages {
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
    margin-bottom: 1.25rem;
  }

  .stage-row {
    display: grid;
    grid-template-columns: 1rem 2.5rem 1fr;
    align-items: center;
    gap: 0.5rem;
    opacity: 0;
    animation: fade-in-up 180ms ease forwards;
  }

  .stage-row:nth-child(1) { animation-delay: 200ms; }
  .stage-row:nth-child(2) { animation-delay: 310ms; }
  .stage-row:nth-child(3) { animation-delay: 420ms; }
  .stage-row:nth-child(4) { animation-delay: 530ms; }
  .stage-row:nth-child(5) { animation-delay: 640ms; }
  .stage-row:nth-child(6) { animation-delay: 750ms; }
  .stage-row:nth-child(7) { animation-delay: 860ms; }

  .stage-glyph {
    font-size: 0.65rem;
    line-height: 1;
  }

  .stage-glyph--done {
    color: var(--color-text-dim);
  }

  .stage-glyph--gov {
    color: var(--color-accent);
  }

  .stage-label {
    color: var(--color-text-dim);
    letter-spacing: 0.04em;
    font-size: 0.75rem;
  }

  .stage-desc {
    color: var(--color-text-muted);
  }

  .stage-approved {
    color: var(--color-accent);
    font-weight: 500;
  }

  .compile-output {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    padding-top: 0.25rem;
    border-top: 1px solid var(--color-border);
  }

  .output-row {
    display: grid;
    grid-template-columns: 10rem 1fr;
    gap: 1rem;
    opacity: 0;
    animation: fade-in-up 180ms ease forwards;
  }

  .output-row:nth-child(1) { animation-delay: 1020ms; }
  .output-row:nth-child(2) { animation-delay: 1100ms; }
  .output-row:nth-child(3) { animation-delay: 1180ms; }

  .output-file {
    color: var(--color-text);
    font-weight: 500;
  }

  .output-action {
    color: var(--color-text-dim);
  }

  /* Headline */
  .hero-headline {
    font-family: var(--font-serif);
    font-size: clamp(2.25rem, 5vw, 3.75rem);
    font-weight: 400;
    line-height: 1.1;
    letter-spacing: -0.01em;
    color: var(--color-text);
    margin: 0 0 1.25rem;
  }

  .hero-sub {
    font-size: 1rem;
    color: var(--color-text-muted);
    line-height: 1.7;
    margin: 0 0 2.5rem;
    max-width: 38rem;
  }

  .hero-actions {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    flex-wrap: wrap;
  }

  /* Buttons */
  .btn-primary {
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--color-bg);
    background-color: var(--color-accent);
    padding: 0.7rem 1.5rem;
    border-radius: 3px;
    transition: background-color 0.12s ease;
    display: inline-block;
  }

  .btn-primary:hover {
    background-color: var(--color-accent-hover);
    color: var(--color-bg);
  }

  .btn-ghost {
    font-size: 0.9375rem;
    color: var(--color-text-muted);
    transition: color 0.12s ease;
  }

  .btn-ghost:hover {
    color: var(--color-text);
  }

  /* ── Sections ─────────────────────────────────────────────────────────── */
  .section {
    padding: 4.5rem 0;
  }

  .section p {
    font-size: 1.0625rem;
    color: var(--color-text-muted);
    line-height: 1.8;
    margin: 0 0 1.25rem;
  }

  .section p:last-child {
    margin-bottom: 0;
  }

  /* ── Recognition ─────────────────────────────────────────────────────── */
  .hook {
    font-size: 1.0625rem !important;
    color: var(--color-text) !important;
    line-height: 1.75 !important;
    margin-bottom: 1.5rem !important;
  }

  /* ── Distinction block ───────────────────────────────────────────────── */
  .distinction {
    border-left: 1px solid var(--color-accent);
    padding-left: 1.5rem;
  }

  .distinction-line {
    font-size: 1.0625rem !important;
    color: var(--color-text) !important;
    line-height: 1.6 !important;
    margin: 0 0 0.625rem !important;
  }

  .distinction-caption {
    font-size: 0.9rem !important;
    color: var(--color-text-muted) !important;
    margin-top: 1rem !important;
  }

  /* ── Mechanism ───────────────────────────────────────────────────────── */
  .lead {
    font-size: 1.25rem !important;
    font-weight: 700;
    color: var(--color-text) !important;
    margin-bottom: 1.5rem !important;
  }

  .result-statement {
    font-size: 1.125rem !important;
    font-weight: 600;
    color: var(--color-text) !important;
    line-height: 1.6 !important;
    margin-top: 2rem !important;
    padding-top: 1.75rem;
    border-top: 1px solid var(--color-border);
  }

  /* ── Artifact ────────────────────────────────────────────────────────── */
  .section-label {
    font-family: var(--font-mono);
    font-size: 0.7rem !important;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-dim) !important;
    margin: 0 0 1.5rem !important;
  }

  /* File listing */
  .file-listing {
    margin-bottom: 2rem;
  }

  .file-row {
    display: grid;
    grid-template-columns: 7rem 1fr;
    gap: 1.5rem;
    padding: 1rem 0;
    border-top: 1px solid var(--color-border);
    align-items: baseline;
  }

  .file-row:last-child {
    border-bottom: 1px solid var(--color-border);
  }

  .file-name {
    font-family: var(--font-mono);
    font-size: 0.875rem;
    color: var(--color-text);
    background: none;
    padding: 0;
    flex-shrink: 0;
  }

  .file-desc {
    font-size: 0.9375rem;
    color: var(--color-text-muted);
    line-height: 1.6;
  }

  /* CLAUDE.md excerpt */
  .excerpt-block {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    margin-bottom: 1.75rem;
    overflow: hidden;
  }

  .excerpt-label {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-text-dim);
    padding: 0.625rem 1.25rem;
    border-bottom: 1px solid var(--color-border);
  }

  .excerpt-content {
    padding: 1rem 1.25rem 1.125rem;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    line-height: 1.65;
  }

  .excerpt-blank {
    height: 0.5rem;
  }

  .excerpt-heading {
    color: var(--color-text);
    font-weight: 600;
  }

  .excerpt-key {
    color: var(--color-text-muted);
    font-weight: 500;
  }

  .excerpt-val {
    color: var(--color-text-dim);
    padding-left: 1rem;
  }

  .file-note {
    font-size: 0.9rem !important;
    color: var(--color-text-dim) !important;
    line-height: 1.65 !important;
  }

  /* ── Invitation ──────────────────────────────────────────────────────── */
  .section--invite {
    padding-bottom: 6rem;
  }

  .install-block {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-family: var(--font-mono);
    margin-bottom: 0.75rem;
  }

  .install-note {
    font-size: 0.8125rem;
    color: var(--color-text-dim);
    margin: 0 0 1.25rem;
    font-family: var(--font-mono);
  }

  .install-prompt {
    color: var(--color-text-dim);
    font-size: 1rem;
    flex-shrink: 0;
  }

  .install-cmd {
    font-size: clamp(0.875rem, 2.5vw, 1.0625rem);
    color: var(--color-accent);
    background: none;
    padding: 0;
    letter-spacing: -0.01em;
    user-select: all;
  }

  .trust-signal {
    font-size: 0.875rem !important;
    color: var(--color-text-dim) !important;
    margin: 0 0 1.5rem !important;
  }

  .invite-link {
    font-size: 0.9375rem;
  }

  /* ── Editorial image ─────────────────────────────────────────────────── */
  .editorial-image {
    width: 100%;
    max-height: 58vh;
    overflow: hidden;
    position: relative;
  }

  .editorial-img {
    width: 100%;
    height: 58vh;
    object-fit: cover;
    object-position: center 30%;
    display: block;
  }

  .editorial-caption {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 1.5rem clamp(1.5rem, 5vw, 4rem);
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.04em;
    color: rgba(232, 230, 223, 0.6);
    background: linear-gradient(to top, rgba(13,13,13,0.55) 0%, transparent 100%);
    margin: 0;
  }

  /* ── Mobile ──────────────────────────────────────────────────────────── */
  @media (max-width: 640px) {
    .editorial-image,
    .editorial-img {
      height: 45vw;
      max-height: 45vw;
    }

    .hero {
      padding: 3.5rem 0 3rem;
    }

    .output-row {
      grid-template-columns: 8rem 1fr;
    }

    .file-row {
      grid-template-columns: 1fr;
      gap: 0.375rem;
    }

    .compile-block {
      font-size: 0.75rem;
    }

    .hero-headline {
      font-size: 2rem;
    }

    .section {
      padding: 3.5rem 0;
    }
  }

  /* Respect reduced-motion preference */
  @media (prefers-reduced-motion: reduce) {
    .hero-diamond { animation: none; opacity: 0.6; }
    .compile-prompt,
    .stage-row,
    .output-row { animation: none; opacity: 1; }
  }
</style>

<script>
  // Scroll-triggered entrance for below-fold sections
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.08 }
  );

  document.querySelectorAll('.animate-in').forEach((el) => observer.observe(el));
</script>
