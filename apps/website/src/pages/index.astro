---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const softwareSchema = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'Ada',
  applicationCategory: 'DeveloperApplication',
  operatingSystem: 'macOS, Linux, Windows',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
  description: 'Ada compiles human intent into governed world-state machines for Claude Code and bounded agents. Semantic compilation + world-state runtime — build complex systems that feel as simple as a calculator.',
  url: 'https://motherlabs.ai',
  publisher: { '@type': 'Organization', name: 'Motherlabs', url: 'https://motherlabs.ai' },
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'What is Ada?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Ada is a semantic operating system. You describe what you want to build in plain language. Ada compiles your intent through an 8-stage pipeline into CLAUDE.md, agent files, delegation contracts, and hooks. Then it stays in the room — tracking world-state as Claude Code builds, running a 5-layer verification stack, enforcing bounded contracts on every agent, and learning from session patterns to improve over time.',
      },
    },
    {
      '@type': 'Question',
      name: 'How is Ada different from MEMORY.md or Claude Code auto-memory?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: "Claude Code's auto-memory records what it observed as it worked — it is retrospective. Ada records what you intend before it starts — it is prospective. One captures drift after it happens. The other prevents it before building begins. They are not the same thing.",
      },
    },
    {
      '@type': 'Question',
      name: 'What does Ada produce?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Ada produces three artifacts: CLAUDE.md (the intent file Claude Code reads on every message turn), agents/ (specialized agent files scoped to bounded contexts), and hooks/ (pre-tool guards that enforce constraints at every tool call boundary). These are plain files you can read and verify before any build starts.',
      },
    },
    {
      '@type': 'Question',
      name: 'What is the intent gap?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'The intent gap is the structural distance between informal natural language requirements and the precise program behavior that gets built. Named in Microsoft Research (2026) as a grand challenge for reliable AI-assisted development. Ada closes it by formalizing intent into CLAUDE.md, agent files, and hook files before Claude Code starts.',
      },
    },
  ],
};
---

<Layout
  title="Ada — Semantic operating system for Claude Code | Motherlabs"
  description="Ada compiles intent into governed world-state machines. 8-stage semantic pipeline, world-state runtime, bounded delegation contracts, 5-layer verification. Build complex agent systems that feel as simple as a calculator."
  schemas={[softwareSchema, faqSchema]}
>
  <Nav />

  <main>

    <!-- ─── HERO ─────────────────────────────────────────────────────────── -->
    <section class="hero">
      <div class="hero-image-wrap" aria-hidden="true">
        <img src="/intent-notes.jpg" alt="" class="hero-image" loading="eager" decoding="async" />
      </div>
      <div class="container hero-content">

        <div class="hero-left">
          <p class="hero-label">Semantic operating system</p>
          <h1 class="hero-headline">
            Intent in.<br />Governed<br />execution out.
          </h1>
          <p class="hero-sub">
            Eight compilation stages. World-state runtime.
            Bounded execution contracts. Ada stays in the room.
          </p>
          <div class="hero-actions">
            <a href="/start" class="btn-primary">Get started</a>
            <a href="/ada" class="btn-ghost">How it works &rarr;</a>
          </div>
        </div>

        <div class="hero-right">
          <div class="compile-block" aria-label="Ada compile output">
            <div class="compile-prompt">
              <span class="prompt-char">$</span>
              <span class="prompt-cmd">ada compile</span>
            </div>
            <div class="compile-stages">
              <div class="stage-row">
                <span class="stage-glyph stage-glyph--done">◆</span>
                <span class="stage-label">CTX</span>
                <span class="stage-desc">codebase context</span>
              </div>
              <div class="stage-row">
                <span class="stage-glyph stage-glyph--done">◆</span>
                <span class="stage-label">INT</span>
                <span class="stage-desc">intent graph</span>
              </div>
              <div class="stage-row">
                <span class="stage-glyph stage-glyph--done">◆</span>
                <span class="stage-label">PER</span>
                <span class="stage-desc">persona mapping</span>
              </div>
              <div class="stage-row">
                <span class="stage-glyph stage-glyph--done">◆</span>
                <span class="stage-label">ENT</span>
                <span class="stage-desc">entity extraction</span>
              </div>
              <div class="stage-row">
                <span class="stage-glyph stage-glyph--done">◆</span>
                <span class="stage-label">PRO</span>
                <span class="stage-desc">process synthesis</span>
              </div>
              <div class="stage-row">
                <span class="stage-glyph stage-glyph--done">◆</span>
                <span class="stage-label">SYN</span>
                <span class="stage-desc">synthesis</span>
              </div>
              <div class="stage-row stage-row--gov">
                <span class="stage-glyph stage-glyph--gov">◈</span>
                <span class="stage-label">GOV</span>
                <span class="stage-desc stage-approved">approved &nbsp; 0.94</span>
              </div>
            </div>
            <div class="compile-output">
              <div class="output-row">
                <span class="output-file">CLAUDE.md</span>
                <span class="output-action">written</span>
              </div>
              <div class="output-row">
                <span class="output-file">agents/</span>
                <span class="output-action">8 files written</span>
              </div>
              <div class="output-row">
                <span class="output-file">contracts/</span>
                <span class="output-action">delegation bounds written</span>
              </div>
              <div class="output-row">
                <span class="output-file">hooks/</span>
                <span class="output-action">pre-tool guards written</span>
              </div>
            </div>
          </div>
        </div>

      </div>
    </section>

    <!-- ─── OUTPUT ──────────────────────────────────────────────────────── -->
    <hr class="divider" />
    <section class="output-section animate-in">
      <div class="container">
        <div class="callouts">
          <div class="callout">
            <div class="callout-dot"></div>
            <div class="callout-body">
              <span class="callout-label">GOV — 0.94</span>
              <p class="callout-text">Semantic gate. The Governor scores coherence between your intent and the compiled blueprint before anything is written.</p>
            </div>
          </div>
          <div class="callout">
            <div class="callout-dot"></div>
            <div class="callout-body">
              <span class="callout-label">CLAUDE.md</span>
              <p class="callout-text">Compiled intent. Injected into every Claude Code context window — every session, every turn.</p>
            </div>
          </div>
          <div class="callout">
            <div class="callout-dot"></div>
            <div class="callout-body">
              <span class="callout-label">hooks/</span>
              <p class="callout-text">Pre-tool guards. Your constraints enforced at the execution boundary — before Claude Code acts, not after.</p>
            </div>
          </div>
          <div class="callout">
            <div class="callout-dot"></div>
            <div class="callout-body">
              <span class="callout-label">World-state runtime</span>
              <p class="callout-text">Ada tracks what has actually been built — world-state, session log, component progress — and runs a 5-layer verification stack as execution proceeds.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ─── ESSENTIAL INFO ───────────────────────────────────────────────── -->
    <hr class="divider" />
    <section class="essential-section">
      <div class="container container--narrow">

        <div class="output-list">
          <div class="output-item">
            <code class="out-file">CLAUDE.md</code>
            <span class="out-desc">The intent file. Claude Code reads this on every message turn — what the system is, what it is not, what constraints apply.</span>
          </div>
          <div class="output-item">
            <code class="out-file">agents/</code>
            <span class="out-desc">Macro planner, micro executors, independent verifier — plus specialist agents scoped to each bounded context.</span>
          </div>
          <div class="output-item">
            <code class="out-file">contracts/</code>
            <span class="out-desc">Delegation contracts. Each agent gets typed scope, stop conditions, required evidence, and a max recursion depth — no unconstrained spawning.</span>
          </div>
          <div class="output-item">
            <code class="out-file">hooks/</code>
            <span class="out-desc">Pre-tool guards. Your intent, enforced at the boundary where decisions are made.</span>
          </div>
        </div>

        <div class="essential-cta">
          <div class="install-block">
            <span class="install-prompt">$</span>
            <code class="install-cmd">ada compile</code>
          </div>
          <div class="essential-links">
            <a href="/start" class="btn-primary">Get started</a>
            <a href="/ada" class="btn-ghost">Read about Ada &rarr;</a>
          </div>
        </div>

      </div>
    </section>

  </main>

  <Footer />
</Layout>

<style>
  /* ── Layout ──────────────────────────────────────────────────────────── */
  .container {
    max-width: 72rem;
    margin: 0 auto;
    padding: 0 clamp(1.5rem, 5vw, 4rem);
  }

  .container--narrow {
    max-width: 44rem;
  }

  .divider {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: 0;
  }

  /* ── Hero ────────────────────────────────────────────────────────────── */
  .hero {
    position: relative;
    min-height: 88vh;
    display: flex;
    align-items: center;
    overflow: hidden;
  }

  .hero-image-wrap {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 25%;
    opacity: 0.42;
    display: block;
  }

  /* Light mode: less opacity since image is bright */
  @media (prefers-color-scheme: light) {
    .hero-image { opacity: 0.34; }
  }
  [data-theme="light"] .hero-image { opacity: 0.34; }
  [data-theme="dark"] .hero-image { opacity: 0.42; }

  .hero-content {
    position: relative;
    z-index: 1;
    padding-top: 6rem;
    padding-bottom: 6rem;
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 6rem;
    align-items: center;
  }

  .hero-left {
    max-width: 28rem;
  }

  .hero-label {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin: 0 0 1.25rem;
  }

  .hero-headline {
    font-family: var(--font-serif);
    font-size: clamp(2.5rem, 5vw, 3.75rem);
    font-weight: 400;
    line-height: 1.08;
    letter-spacing: -0.015em;
    color: var(--color-text);
    margin: 0 0 1.5rem;
  }

  .hero-sub {
    font-family: var(--font-mono);
    font-size: 0.875rem;
    color: var(--color-text-muted);
    line-height: 1.75;
    margin: 0 0 2.5rem;
  }

  .hero-actions {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    flex-wrap: wrap;
  }

  .hero-right {
    flex-shrink: 0;
  }

  /* Buttons */
  .btn-primary {
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--color-bg);
    background-color: var(--color-accent);
    padding: 0.7rem 1.5rem;
    border-radius: 8px;
    transition: background-color 0.12s ease;
    display: inline-block;
  }

  .btn-primary:hover {
    background-color: var(--color-accent-hover);
    color: var(--color-bg);
  }

  .btn-ghost {
    font-size: 0.9375rem;
    color: var(--color-text-muted);
    transition: color 0.12s ease;
  }

  .btn-ghost:hover {
    color: var(--color-text);
  }

  /* ── Output/callout section ──────────────────────────────────────────── */
  .output-section {
    padding: 4rem 0;
  }

  /* Compile block — in hero */
  .compile-block {
    font-family: var(--font-mono);
    font-size: 0.875rem;
    line-height: 1.6;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    padding: 1.5rem 1.75rem;
    display: inline-flex;
    flex-direction: column;
    gap: 0;
    min-width: 22rem;
  }

  .compile-prompt {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 1.25rem;
    opacity: 0;
    animation: fade-in-up 180ms ease forwards;
    animation-delay: 80ms;
  }

  .prompt-char { color: var(--color-text-dim); }
  .prompt-cmd  { color: var(--color-text-muted); }

  .compile-stages {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    margin-bottom: 1.25rem;
  }

  .stage-row {
    display: grid;
    grid-template-columns: 1rem 2.5rem 1fr;
    align-items: center;
    gap: 0.5rem;
    padding: 0.1rem 0;
    opacity: 0;
    animation: fade-in-up 180ms ease forwards;
  }

  .stage-row--gov {
    margin-top: 0.125rem;
  }

  .stage-row:nth-child(1) { animation-delay: 200ms; }
  .stage-row:nth-child(2) { animation-delay: 310ms; }
  .stage-row:nth-child(3) { animation-delay: 420ms; }
  .stage-row:nth-child(4) { animation-delay: 530ms; }
  .stage-row:nth-child(5) { animation-delay: 640ms; }
  .stage-row:nth-child(6) { animation-delay: 750ms; }
  .stage-row:nth-child(7) { animation-delay: 860ms; }

  .stage-glyph      { font-size: 0.65rem; line-height: 1; }
  .stage-glyph--done { color: var(--color-text-dim); }
  .stage-glyph--gov  { color: var(--color-accent); }
  .stage-label       { color: var(--color-text-dim); letter-spacing: 0.04em; font-size: 0.8rem; }
  .stage-desc        { color: var(--color-text-muted); font-size: 0.8125rem; }
  .stage-approved    { color: var(--color-accent); font-weight: 500; }

  .compile-output {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    padding-top: 1rem;
    border-top: 1px solid var(--color-border);
  }

  .output-row {
    display: grid;
    grid-template-columns: 9rem 1fr;
    gap: 1rem;
    opacity: 0;
    animation: fade-in-up 180ms ease forwards;
  }

  .output-row:nth-child(1) { animation-delay: 1020ms; }
  .output-row:nth-child(2) { animation-delay: 1100ms; }
  .output-row:nth-child(3) { animation-delay: 1180ms; }

  .output-file   { color: var(--color-text); font-weight: 500; }
  .output-action { color: var(--color-text-dim); }

  /* Callouts — horizontal row */
  .callouts {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 3rem;
  }

  .callout {
    display: flex;
    align-items: flex-start;
    gap: 0.875rem;
  }

  .callout-dot {
    flex-shrink: 0;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background-color: var(--color-accent);
    margin-top: 0.45em;
  }

  .callout-body {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .callout-label {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--color-text);
    letter-spacing: 0.02em;
  }

  .callout-text {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    line-height: 1.65;
    margin: 0;
  }

  /* ── Essential info ──────────────────────────────────────────────────── */
  .essential-section {
    padding: 5rem 0 6rem;
  }

  .output-list {
    display: flex;
    flex-direction: column;
    margin-bottom: 3.5rem;
  }

  .output-item {
    display: grid;
    grid-template-columns: 8rem 1fr;
    gap: 1.5rem;
    padding: 1.125rem 0;
    border-top: 1px solid var(--color-border);
    align-items: baseline;
  }

  .output-item:last-child {
    border-bottom: 1px solid var(--color-border);
  }

  .out-file {
    font-family: var(--font-mono);
    font-size: 0.875rem;
    color: var(--color-text);
    font-weight: 500;
    background: none;
    padding: 0;
  }

  .out-desc {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    line-height: 1.65;
  }

  .essential-cta {
    padding-top: 2.5rem;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .install-block {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-family: var(--font-mono);
  }

  .install-prompt {
    color: var(--color-text-dim);
    font-size: 1rem;
    flex-shrink: 0;
  }

  .install-cmd {
    font-family: var(--font-mono);
    font-size: clamp(1rem, 2.5vw, 1.25rem);
    color: var(--color-accent);
    background: none;
    padding: 0;
    letter-spacing: -0.01em;
  }

  .essential-links {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    flex-wrap: wrap;
  }

  /* ── Mobile ──────────────────────────────────────────────────────────── */
  @media (max-width: 900px) {
    .hero-content {
      grid-template-columns: 1fr;
      gap: 3rem;
    }

    .hero-right {
      order: -1;
    }

    .compile-block {
      min-width: 0;
      width: 100%;
    }

    .callouts {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
  }

  @media (max-width: 640px) {
    .hero {
      min-height: auto;
    }

    .hero-content {
      padding-top: 4rem;
      padding-bottom: 4rem;
    }

    .hero-headline {
      font-size: 2.25rem;
    }

    .output-item {
      grid-template-columns: 1fr;
      gap: 0.375rem;
    }
  }

  /* Reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .compile-prompt,
    .stage-row,
    .output-row { animation: none; opacity: 1; }
  }
</style>

<script>
  // Scroll-triggered entrance for below-fold sections
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.08 }
  );

  document.querySelectorAll('.animate-in').forEach((el) => observer.observe(el));
</script>
