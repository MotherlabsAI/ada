---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const orgSchema = {
  '@context': 'https://schema.org',
  '@type': 'ResearchOrganization',
  name: 'Motherlabs',
  url: 'https://motherlabs.ai',
  description: 'Research lab building Motherlabs MCP — the substrate layer for the agent economy.',
  founder: { '@type': 'Person', name: 'Alex Roze' },
  location: { '@type': 'Place', name: 'Vancouver, BC' },
};
---

<Layout
  title="Motherlabs — the substrate layer for the agent economy"
  description="A research lab building Motherlabs MCP: a typed, governed, content-addressed world model every agent inhabits. Not a memory MCP. Not a tool wrapper. The substrate."
  schemas={[orgSchema]}
>
  <Nav />

  <main>

    <!-- ─── HERO ────────────────────────────────────────────────────── -->
    <section class="hero">
      <div class="wrap hero-wrap">
        <div class="hero-meta">
          <span class="label label-accent">◆ Motherlabs Research</span>
          <span class="label">Est. 2025 · Vancouver</span>
        </div>

        <h1 class="hero-headline">
          The substrate<br />
          <span class="hero-accent">every agent</span><br />
          will inhabit.
        </h1>

        <p class="hero-sub">
          Memory MCPs record what was said. Tool MCPs deliver actions.
          Neither models the world an agent acts upon. That layer is missing —
          and it is what we build.
        </p>

        <div class="hero-tags">
          <span>Typed primitives</span>
          <span class="sep">/</span>
          <span>Content-addressed</span>
          <span class="sep">/</span>
          <span>Governed at action-time</span>
          <span class="sep">/</span>
          <span>Local-first</span>
        </div>
      </div>
    </section>

    <hr class="rule" />

    <!-- ─── THESIS ──────────────────────────────────────────────────── -->
    <section id="thesis" class="section">
      <div class="wrap grid-2">
        <div class="col-label">
          <span class="label">§ 01 — Thesis</span>
        </div>
        <div class="col-body">
          <h2 class="h-xl">Context is infrastructure.</h2>
          <p class="body-lg">
            Agents do not fail because models are weak. They fail because
            the world they reason over is a transcript — flat, untyped,
            ungoverned, ephemeral. Every new session rebuilds it from scratch.
          </p>
          <p class="body-lg">
            A substrate changes that. One typed world model. Six primitives.
            Nine layers. One protocol surface. Any agent, any vendor, any
            session reads, writes under governance, and transacts through it.
          </p>
          <div class="callout">
            <span class="label label-accent">The bet</span>
            <p>
              The MCP standard has won as the protocol surface. Every serious
              agent speaks it. But every existing MCP serves one layer —
              tool calls. The substrate slot underneath is unoccupied.
            </p>
          </div>
        </div>
      </div>
    </section>

    <hr class="rule" />

    <!-- ─── SYSTEMS ─────────────────────────────────────────────────── -->
    <section id="systems" class="section">
      <div class="wrap">
        <div class="section-head">
          <span class="label">§ 02 — Systems</span>
          <h2 class="h-xl">What is being built.</h2>
        </div>

        <div class="systems">

          <article class="system system--flagship">
            <header class="system-head">
              <span class="label label-accent">Flagship · in development</span>
              <h3 class="h-lg">Motherlabs MCP</h3>
            </header>
            <p class="body-md">
              A typed, governed, content-addressed world model exposed through
              an MCP server. Six primitives — Entity, Relation, Process,
              Constraint, Commitment, Address — under git-like content hashing.
              Every write goes through a governor that can <em>ALLOW</em>,
              <em>BLOCK</em>, or <em>AMEND_FIRST</em> before the tool call.
            </p>

            <div class="layers">
              <span>Identity</span>
              <span>World</span>
              <span>Invariants</span>
              <span>Processes</span>
              <span>Authority</span>
              <span>Gate</span>
              <span>Evidence</span>
              <span>Commitment</span>
              <span>Coherence</span>
            </div>

            <div class="system-meta">
              <div><span class="label">Surface</span><p>25 typed tools</p></div>
              <div><span class="label">Storage</span><p>.ml/ · git-object · SQLite</p></div>
              <div><span class="label">Stance</span><p>Local-first · vendor-neutral</p></div>
            </div>

            <pre class="code"><code>{`$ mcp add motherlabs
  → substrate initialized at .ml/
  → 6 primitives · 9 layers · 25 tools

agent.call("ml.gate", { action: "write", target: "ENT.07" })
  → AMEND_FIRST
  → violated: [INV.03 — name must be unique in scope]
  → suggested: { name: "Customer_v2" }`}</code></pre>
          </article>

          <article class="system">
            <header class="system-head">
              <span class="label">Compiler · live</span>
              <h3 class="h-md">Ada</h3>
            </header>
            <p class="body-md">
              The compile step that births a substrate from natural-language
              intent. A nine-stage gated pipeline — INT → PER → ENT → PRO →
              SYN → AUD → GOV — each stage reducing ambiguity, each artifact
              carrying a postcode that traces back to the original intent.
            </p>
            <p class="body-sm muted">
              Ada is how substrates enter the world. Motherlabs MCP is how
              agents operate through them.
            </p>
          </article>

          <article class="system">
            <header class="system-head">
              <span class="label">Runtime · building</span>
              <h3 class="h-md">Agentic City</h3>
            </header>
            <p class="body-md">
              Multi-agent operating system at scale. Typed delegation
              contracts, commitment ledger, authority graph. The layer where
              substrates become civic infrastructure for fleets of agents
              that must coordinate, transact, and remain coherent across
              sessions and vendors.
            </p>
          </article>

        </div>
      </div>
    </section>

    <hr class="rule" />

    <!-- ─── CATEGORICAL ─────────────────────────────────────────────── -->
    <section class="section">
      <div class="wrap grid-2">
        <div class="col-label">
          <span class="label">§ 03 — Category</span>
        </div>
        <div class="col-body">
          <h2 class="h-xl">Not memory. Not a tool wrapper.</h2>

          <div class="compare">
            <div class="compare-row compare-row--head">
              <span></span>
              <span>Memory MCP</span>
              <span>Tool MCP</span>
              <span class="mark">Motherlabs MCP</span>
            </div>
            <div class="compare-row">
              <span class="k">Typed world model</span>
              <span>—</span><span>—</span><span class="v">✓</span>
            </div>
            <div class="compare-row">
              <span class="k">Action-time gate</span>
              <span>—</span><span>—</span><span class="v">✓</span>
            </div>
            <div class="compare-row">
              <span class="k">Executable invariants</span>
              <span>—</span><span>—</span><span class="v">✓</span>
            </div>
            <div class="compare-row">
              <span class="k">Provenance DAG</span>
              <span>—</span><span>—</span><span class="v">✓</span>
            </div>
            <div class="compare-row">
              <span class="k">Inter-agent commitments</span>
              <span>—</span><span>—</span><span class="v">✓</span>
            </div>
            <div class="compare-row">
              <span class="k">Drift signal</span>
              <span>—</span><span>—</span><span class="v">✓</span>
            </div>
          </div>

          <p class="body-md muted">
            A memory MCP without a substrate is a transcript. A substrate
            without a memory MCP still works — the substrate <em>is</em>
            the durable world. The substrate is upstream.
          </p>
        </div>
      </div>
    </section>

    <hr class="rule" />

    <!-- ─── TIMELINE ────────────────────────────────────────────────── -->
    <section id="timeline" class="section">
      <div class="wrap">
        <div class="section-head">
          <span class="label">§ 04 — Timeline</span>
          <h2 class="h-xl">Fourteen months. Eight architectures. One seed.</h2>
        </div>

        <ol class="timeline">
          <li>
            <span class="t-date">2025 · Q1</span>
            <span class="t-title">Tattoo OS</span>
            <span class="t-note">First attempt at a governed system. Taught us the compile step.</span>
          </li>
          <li>
            <span class="t-date">2025 · Q2</span>
            <span class="t-title">SEED protocol · GENOME spec</span>
            <span class="t-note">200 properties. The shape of what a substrate has to carry.</span>
          </li>
          <li>
            <span class="t-date">2025 · Q3</span>
            <span class="t-title">The two-forces model</span>
            <span class="t-note">Entropy collapse + autopoiesis as the ground for agent architecture.</span>
          </li>
          <li>
            <span class="t-date">2025 · Q4</span>
            <span class="t-title">Ada compiler</span>
            <span class="t-note">Nine-stage pipeline. Postcode provenance. First production output.</span>
          </li>
          <li>
            <span class="t-date">2026 · Q1</span>
            <span class="t-title">The collapse</span>
            <span class="t-note">Eight architectures converge. Markdown was the wrong shape. MCP is the right one.</span>
          </li>
          <li class="t-current">
            <span class="t-date">2026 · Q2</span>
            <span class="t-title">Motherlabs MCP</span>
            <span class="t-note">Substrate layer. 25 tools. 3-week engineering lead. No novel research required.</span>
          </li>
        </ol>
      </div>
    </section>

    <hr class="rule" />

    <!-- ─── BIO ─────────────────────────────────────────────────────── -->
    <section id="bio" class="section">
      <div class="wrap grid-2">
        <div class="col-label">
          <span class="label">§ 05 — Bio</span>
        </div>
        <div class="col-body">
          <h2 class="h-xl">Alex Roze.</h2>
          <p class="body-lg">
            Solo founder. Self-taught. Tattoo artist turned semantic
            compiler author. Vancouver, with a second studio in Kelowna.
            Motherlabs is the lab; the work is the substrate underneath
            every agent that will exist.
          </p>
          <p class="body-md muted">
            This is a research page — not a pitch, not a product tour.
            The system ships when the system is right.
          </p>
          <div class="contact">
            <a href="mailto:alex@motherlabs.ai">alex@motherlabs.ai</a>
            <a href="https://github.com/motherlabs" target="_blank" rel="noopener noreferrer">github.com/motherlabs</a>
          </div>
        </div>
      </div>
    </section>

  </main>

  <Footer />
</Layout>

<style>
  main { display: block; }

  /* ─── Hero ─── */
  .hero {
    padding: 7rem 0 6rem;
  }

  .hero-wrap {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }

  .hero-meta {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .hero-headline {
    font-size: clamp(3.25rem, 9vw, 7rem);
    line-height: 0.95;
    max-width: 18ch;
  }

  .hero-accent {
    color: var(--color-accent);
  }

  .hero-sub {
    font-family: var(--font-mono);
    font-size: 1.0625rem;
    line-height: 1.7;
    color: var(--color-text-muted);
    max-width: 58ch;
  }

  .hero-tags {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-text-dim);
    padding-top: 1rem;
  }

  .hero-tags .sep { color: var(--color-border); }

  /* ─── Section primitives ─── */
  .section {
    padding: 6rem 0;
  }

  .section-head {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    margin-bottom: 3.5rem;
    max-width: 58ch;
  }

  .grid-2 {
    display: grid;
    grid-template-columns: 10rem 1fr;
    gap: 4rem;
  }

  .col-label { padding-top: 0.4rem; }

  .col-body {
    display: flex;
    flex-direction: column;
    gap: 1.75rem;
    max-width: 62ch;
  }

  .h-xl {
    font-size: clamp(2.25rem, 4vw, 3.25rem);
  }

  .h-lg {
    font-size: clamp(1.75rem, 3vw, 2.375rem);
    font-family: var(--font-serif);
    font-style: italic;
    font-weight: 400;
    line-height: 1.1;
  }

  .h-md {
    font-size: 1.5rem;
    font-family: var(--font-serif);
    font-style: italic;
    font-weight: 400;
  }

  .body-lg {
    font-family: var(--font-mono);
    font-size: 0.9375rem;
    line-height: 1.75;
    color: var(--color-text);
  }

  .body-md {
    font-family: var(--font-mono);
    font-size: 0.875rem;
    line-height: 1.7;
    color: var(--color-text);
  }

  .body-sm {
    font-size: 0.8125rem;
    line-height: 1.65;
  }

  .muted { color: var(--color-text-muted); }

  .callout {
    border-left: 1px solid var(--color-accent);
    padding: 0.25rem 0 0.25rem 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .callout p {
    font-family: var(--font-mono);
    font-size: 0.875rem;
    line-height: 1.7;
    color: var(--color-text-muted);
  }

  /* ─── Systems ─── */
  .systems {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .system {
    padding: 3rem 0;
    border-top: 1px solid var(--color-border);
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .system:last-child { border-bottom: 1px solid var(--color-border); }

  .system--flagship {
    padding: 3.5rem 0;
  }

  .system-head {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .layers {
    display: flex;
    flex-wrap: wrap;
    gap: 0;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  .layers span {
    padding: 0.4rem 0.9rem 0.4rem 0;
    border-right: 1px solid var(--color-border);
    margin-right: 0.9rem;
    margin-bottom: 0.25rem;
  }

  .layers span:last-child { border-right: 0; }

  .system-meta {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    padding: 1rem 0;
    border-top: 1px dashed var(--color-border);
    border-bottom: 1px dashed var(--color-border);
  }

  .system-meta > div {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .system-meta p {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--color-text);
  }

  .code {
    margin: 0;
    background-color: var(--color-surface);
  }

  /* ─── Compare table ─── */
  .compare {
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
    margin: 0.5rem 0;
  }

  .compare-row {
    display: grid;
    grid-template-columns: 1.6fr 1fr 1fr 1fr;
    gap: 1rem;
    padding: 0.85rem 0;
    border-bottom: 1px solid var(--color-border);
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    align-items: center;
  }

  .compare-row:last-child { border-bottom: 0; }

  .compare-row--head {
    color: var(--color-text-dim);
    font-size: 0.7rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .compare-row--head .mark { color: var(--color-accent); }

  .compare-row .k { color: var(--color-text-muted); }
  .compare-row .v { color: var(--color-accent); }

  /* ─── Timeline ─── */
  .timeline {
    list-style: none;
    margin: 0;
    padding: 0;
    border-top: 1px solid var(--color-border);
  }

  .timeline li {
    display: grid;
    grid-template-columns: 9rem 14rem 1fr;
    gap: 2rem;
    padding: 1.25rem 0;
    border-bottom: 1px solid var(--color-border);
    align-items: baseline;
  }

  .t-date {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-text-dim);
  }

  .t-title {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 1.125rem;
    color: var(--color-text);
  }

  .t-note {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    line-height: 1.6;
  }

  .t-current .t-title { color: var(--color-accent); }
  .t-current .t-date { color: var(--color-accent); }

  /* ─── Bio ─── */
  .contact {
    display: flex;
    gap: 2rem;
    padding-top: 0.5rem;
    font-family: var(--font-mono);
    font-size: 0.875rem;
    flex-wrap: wrap;
  }

  /* ─── Responsive ─── */
  @media (max-width: 768px) {
    .hero { padding: 4rem 0 3.5rem; }
    .section { padding: 4rem 0; }

    .grid-2 {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }

    .system-meta {
      grid-template-columns: 1fr;
      gap: 1rem;
    }

    .compare-row {
      grid-template-columns: 1.2fr 0.6fr 0.6fr 0.7fr;
      font-size: 0.72rem;
      gap: 0.5rem;
    }

    .timeline li {
      grid-template-columns: 1fr;
      gap: 0.35rem;
      padding: 1rem 0;
    }

    .hero-headline { max-width: 100%; }
  }
</style>

<script>
  const io = new IntersectionObserver(
    (entries) => {
      entries.forEach((e) => {
        if (e.isIntersecting) {
          e.target.classList.add('is-visible');
          io.unobserve(e.target);
        }
      });
    },
    { threshold: 0.12 }
  );

  document.querySelectorAll('.animate-in').forEach((el) => io.observe(el));
</script>
