---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'How does Ada work step by step?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Ada works in two arcs. Compile arc: (1) You run `ada compile`. (2) Ada elicits — asks the minimum questions to resolve blocking unknowns. (3) Ada compiles through 8 stages: CTX, INT, PER, ENT, PRO, SYN, VER, GOV. (4) Files land: CLAUDE.md, agents/, contracts/, hooks/. Runtime arc: (5) Ada stays in the room — PostToolUse hooks log every tool call to a session log. (6) The macro planner calls `ada.get_macro_plan` to get the dependency-ordered task list. (7) It delegates bounded tasks to domain agents operating under typed delegation contracts. (8) An independent verifier checks each output against blueprint postconditions. (9) `ada.verify` runs a 5-layer stack: structural, execution, policy, outcome, provenance. (10) `ada.extract_skills` finds repeated session patterns and proposes skill candidates for human approval.',
      },
    },
    {
      '@type': 'Question',
      name: 'What questions does Ada ask during elicitation?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Ada asks semantic questions, not technical ones. Not "which framework?" but "what should happen when a user does X?" Not "SQL or NoSQL?" but "what entities need to exist and what are their boundaries?" The elicitation session surfaces: what the system should do, what it explicitly should not do, who uses it and how, what constraints are non-negotiable, and what decisions have already been made. These are the questions that resolve the blocking unknowns that would otherwise cause the wrong system to be built.',
      },
    },
    {
      '@type': 'Question',
      name: 'How long does an Ada compilation take?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'A typical Ada compilation takes 10-20 minutes total: 5-10 minutes for the elicitation session (depending on project complexity and how many unknowns need resolving), and 2-5 minutes for the compilation pipeline to run. The result is hundreds of CLAUDE.md, agents, and hooks ready for Claude Code to use.',
      },
    },
    {
      '@type': 'Question',
      name: 'Do I need technical knowledge to use Ada?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'No. Ada operates at the semantic level — what the system should do, not how it should be built. You describe your project at whatever level you think in. Ada infers technical choices from conceptual descriptions and asks questions about behavior and intent, not implementation. The elicitation session is designed for people who know what they want to build but not necessarily how to build it.',
      },
    },
  ],
};
---

<Layout
  title="How Ada works — semantic compiler + governed runtime | Motherlabs"
  description="Ada runs in two arcs: compile (elicitation + 8-stage pipeline + artifacts on disk) and runtime (world-state tracking, macro/micro execution, delegation contracts, 5-layer verification, skill extraction). No technical knowledge required."
  schemas={[faqSchema]}
>
  <Nav />

  <main>
    <section class="page-hero">
      <div class="container">
        <p class="eyebrow"><a href="/ada">Ada</a> &rarr; How Ada Works</p>
        <h1>How Ada works</h1>
        <p class="hero-sub">
          Two arcs: compile and runtime. Ada compiles your intent, then stays in the room.
          No technical knowledge required.
        </p>
      </div>
    </section>

    <hr class="divider" />

    <!-- Phase 1: Install -->
    <section class="section">
      <div class="container container--prose">
        <div class="phase-marker">
          <span class="phase-num">Phase 01</span>
          <h2>Install and run</h2>
        </div>

        <div class="code-block">
          <div class="code-prompt"><span class="prompt-char">$</span> git clone https://github.com/alexrozex/ada</div>
          <div class="code-prompt"><span class="prompt-char">$</span> cd your-project &amp;&amp; ada compile</div>
        </div>

        <p>
          Ada runs in your terminal. No account required. No API key setup for first use.
          You run it in your project directory — Ada detects the codebase context
          automatically as part of the CTX stage.
        </p>
        <p>
          If you're starting a new project with no existing code, that's fine too.
          Ada compiles from intent — the codebase context stage simply notes that
          the project is greenfield.
        </p>
      </div>
    </section>

    <hr class="divider" />

    <!-- Phase 2: Elicitation -->
    <section class="section section--surface">
      <div class="container container--prose">
        <div class="phase-marker">
          <span class="phase-num">Phase 02</span>
          <h2>Elicitation — the questions that matter</h2>
        </div>

        <p>
          Before Ada compiles, it runs structured elicitation.
          This is a focused dialogue session designed to surface the blocking unknowns —
          the things Ada genuinely doesn't know that would cause the wrong system to be built.
        </p>
        <p>
          Ada asks semantic questions, not technical ones.
        </p>

        <div class="example-dialogue">
          <div class="dialogue-exchange">
            <span class="dialogue-who">Ada</span>
            <p class="dialogue-text">You described a "dashboard." Who sees it — the person who owns the data, or someone they grant access to?</p>
          </div>
          <div class="dialogue-exchange dialogue-exchange--you">
            <span class="dialogue-who dialogue-who--you">You</span>
            <p class="dialogue-text">The owner only. This is a private view. No sharing.</p>
          </div>
          <div class="dialogue-exchange">
            <span class="dialogue-who">Ada</span>
            <p class="dialogue-text">The data updates in real time, or on a schedule?</p>
          </div>
          <div class="dialogue-exchange dialogue-exchange--you">
            <span class="dialogue-who dialogue-who--you">You</span>
            <p class="dialogue-text">Daily. It's a digest — not a live view.</p>
          </div>
        </div>

        <p>
          Each question corresponds to an unknown that would force an assumption in the
          compilation. Ada asks the minimum set of questions to resolve them —
          not everything, just what blocks the right output.
        </p>
        <p>
          The questions surface: what the system should do, what it should not do,
          who uses it, what constraints are non-negotiable, what decisions are already made.
          You answer in plain language. Ada handles the rest.
        </p>
      </div>
    </section>

    <hr class="divider" />

    <!-- Phase 3: Compilation -->
    <section class="section">
      <div class="container container--prose">
        <div class="phase-marker">
          <span class="phase-num">Phase 03</span>
          <h2>8-stage compilation</h2>
        </div>

        <p>
          Once elicitation is complete, Ada compiles. The pipeline runs automatically —
          you watch the stages pass.
        </p>

        <div class="compile-block" aria-label="Ada compile output">
          <div class="compile-prompt">
            <span class="prompt-char">$</span>
            <span class="prompt-cmd">ada compile</span>
          </div>
          <div class="compile-stages">
            <div class="stage-row"><span class="stage-label">CTX</span><span class="stage-check">✓</span><span class="stage-desc">codebase context</span></div>
            <div class="stage-row"><span class="stage-label">INT</span><span class="stage-check">✓</span><span class="stage-desc">intent graph</span></div>
            <div class="stage-row"><span class="stage-label">PER</span><span class="stage-check">✓</span><span class="stage-desc">persona mapping</span></div>
            <div class="stage-row"><span class="stage-label">ENT</span><span class="stage-check">✓</span><span class="stage-desc">entity extraction</span></div>
            <div class="stage-row"><span class="stage-label">PRO</span><span class="stage-check">✓</span><span class="stage-desc">process synthesis</span></div>
            <div class="stage-row"><span class="stage-label">SYN</span><span class="stage-check">✓</span><span class="stage-desc">synthesis</span></div>
            <div class="stage-row"><span class="stage-label">GOV</span><span class="stage-check">✓</span><span class="stage-desc stage-approved">approved &nbsp; 0.94</span></div>
          </div>
        </div>

        <p>
          Each stage reduces ambiguity in one dimension. CTX grounds the compilation
          in real codebase state. INT structures your answers into a formal intent graph.
          PER maps who uses the system and how that shapes decisions.
          ENT extracts the canonical domain entities. PRO synthesizes the state machines
          and workflows. SYN assembles all layers into the output artifacts.
          GOV evaluates coherence — and iterates if it doesn't pass.
        </p>
        <p>
          The 0.94 coherence score means the compiled output closely traces back to
          the stated intent. The Governor does not approve until it passes threshold.
        </p>
      </div>
    </section>

    <hr class="divider" />

    <!-- Phase 4: Artifacts -->
    <section class="section section--surface">
      <div class="container container--prose">
        <div class="phase-marker">
          <span class="phase-num">Phase 04</span>
          <h2>Files on disk — verify, then build</h2>
        </div>

        <div class="output-block">
          <div class="output-row">
            <code class="output-file">CLAUDE.md</code>
            <span class="output-action">written</span>
          </div>
          <div class="output-row">
            <code class="output-file">agents/</code>
            <span class="output-action">8 files written</span>
          </div>
          <div class="output-row">
            <code class="output-file">hooks/</code>
            <span class="output-action">pre-tool guards written</span>
          </div>
        </div>

        <p>
          Plain files. You read them before handing to Claude Code.
        </p>
        <p>
          CLAUDE.md is the first thing to read. Does it match what you meant?
          If yes: open Claude Code. It reads CLAUDE.md on every turn and builds
          against what Ada wrote. If no: run <code class="inline-code">ada compile</code> again
          with the correction — Ada's elicitation picks up where you diverged.
        </p>
        <p>
          The agents and hooks run automatically — you don't need to configure them.
          Claude Code loads the relevant agent for each domain context.
          The hooks enforce constraints at every tool call, silently.
        </p>
        <p>
          The session pattern: Ada compiles once. Claude Code builds for as many sessions
          as you need, always within the intent Ada encoded.
          When scope changes significantly: re-run Ada to update the artifacts.
        </p>
      </div>
    </section>

    <hr class="divider" />

    <!-- Phase 5: Runtime -->
    <section class="section">
      <div class="container container--prose">
        <div class="phase-marker">
          <span class="phase-num">Phase 05</span>
          <h2>Runtime — Ada stays in the room</h2>
        </div>

        <p>
          After compile, Ada doesn't disappear. Every tool call Claude Code makes
          is logged to a session record. Ada tracks world-state — what components
          have been implemented, which files were written, what decisions were made.
        </p>

        <p>
          The <strong>macro planner agent</strong> reads <code class="inline-code">ada.get_macro_plan</code>
          at the start of each session. It gets a dependency-ordered task list: what's done,
          what's next, what's blocked. It delegates bounded units of work to domain agents
          under typed <strong>delegation contracts</strong>.
        </p>

        <p>
          A delegation contract is a typed bound on what an agent can do:
          allowed file paths, permitted tools, stop conditions, required evidence before
          returning, and a max recursion depth. No unconstrained spawning.
          Every child agent knows exactly what it's allowed to do and when it must report up.
        </p>

        <div class="output-block">
          <div class="output-row">
            <code class="output-file">ada.get_macro_plan</code>
            <span class="output-action">dependency-ordered task list</span>
          </div>
          <div class="output-row">
            <code class="output-file">ada.get_contract</code>
            <span class="output-action">typed scope + stop conditions</span>
          </div>
          <div class="output-row">
            <code class="output-file">ada.verify</code>
            <span class="output-action">5-layer verification stack</span>
          </div>
          <div class="output-row">
            <code class="output-file">ada.check_drift</code>
            <span class="output-action">alignment with compiled intent</span>
          </div>
        </div>

        <p>
          The <strong>independent verifier</strong> — separated from the executor —
          checks each completed task against blueprint postconditions and entity invariants.
          It cannot self-report success on work it implemented.
        </p>
      </div>
    </section>

    <hr class="divider" />

    <!-- Phase 6: Improvement -->
    <section class="section section--surface">
      <div class="container container--prose">
        <div class="phase-marker">
          <span class="phase-num">Phase 06</span>
          <h2>Self-improvement — offline, benchmarked, human-approved</h2>
        </div>

        <p>
          Ada observes its own sessions. When the same implementation pattern
          appears across multiple sessions — the same sequence of files created,
          the same tool sequence, the same bounded context — Ada proposes it as
          a skill candidate.
        </p>

        <p>
          Skill candidates go into a review queue. You run <code class="inline-code">ada review-skills</code>
          and see each candidate with its evidence: which sessions it came from,
          what files were produced, what the proposed skill prompt looks like.
          You approve or reject. Approved skills land in <code class="inline-code">.claude/skills/</code>
          and are available in the next Claude Code session.
        </p>

        <p>
          The governance core is immutable. Compiled intent, entity invariants,
          and delegation contracts cannot be touched by self-improvement.
          Ada improves workflows and skills. It does not rewrite the constitution.
        </p>

        <div class="output-block">
          <div class="output-row">
            <code class="output-file">ada.extract_skills</code>
            <span class="output-action">analyze session patterns</span>
          </div>
          <div class="output-row">
            <code class="output-file">ada review-skills</code>
            <span class="output-action">human approval required</span>
          </div>
          <div class="output-row">
            <code class="output-file">ada review-amendments</code>
            <span class="output-action">apply blueprint corrections</span>
          </div>
        </div>
      </div>
    </section>

    <hr class="divider" />

    <section class="section">
      <div class="container container--prose">
        <h2>Who this is for</h2>
        <p>
          Ada works at whatever level you think in. You don't need to know
          which database to use or which framework to pick. Ada infers technical
          choices from conceptual descriptions.
        </p>
        <p>
          The only requirement: you need to know what the system should do.
          Not in technical terms — in behavioral ones. "When a user does X, Y should happen."
          "This is for people who need Z, not people who need W."
          "This is not a [category]."
        </p>
        <p>
          That's the level Ada works at. Everything below it is Ada's to handle.
        </p>
        <a href="/ada" class="link-arrow">Full Ada documentation &rarr;</a>
      </div>
    </section>

    <hr class="divider" />
    <section class="section section--invite">
      <div class="container container--prose">
        <div class="install-block">
          <span class="install-prompt">$</span>
          <code class="install-cmd">git clone https://github.com/alexrozex/ada</code>
        </div>
        <p class="trust-signal">~400 iterations since late 2024. Built by one person.</p>
        <a href="/start" class="btn-primary">Full setup guide &rarr;</a>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<style>
  .container { max-width: 72rem; margin: 0 auto; padding: 0 clamp(1.5rem, 5vw, 4rem); }
  .container--prose { max-width: 44rem; }
  .divider { border: none; border-top: 1px solid var(--color-border); margin: 0; }

  .page-hero { padding: 4.5rem 0 3.5rem; }
  .eyebrow { font-family: var(--font-mono); font-size: 0.7rem; letter-spacing: 0.06em; color: var(--color-text-dim); margin: 0 0 1.25rem; display: block; }
  .eyebrow a { color: var(--color-accent); }
  .page-hero h1 { font-family: var(--font-serif); font-size: clamp(1.875rem, 4vw, 2.875rem); font-weight: 400; letter-spacing: -0.01em; line-height: 1.1; margin: 0 0 1.25rem; }
  .hero-sub { font-size: 1.0625rem; color: var(--color-text-muted); max-width: 38rem; margin: 0; line-height: 1.7; }

  .section { padding: 4.5rem 0; }
  .section--surface { background-color: var(--color-surface); }
  .section p { font-size: 1.0625rem; color: var(--color-text-muted); line-height: 1.8; margin: 0 0 1.25rem; }
  .section p:last-child { margin-bottom: 0; }
  .section h2 { font-family: var(--font-serif); font-size: clamp(1.5rem, 3vw, 2rem); font-weight: 400; color: var(--color-text); margin: 0 0 1.5rem; }

  .phase-marker { margin-bottom: 1.75rem; }
  .phase-num { font-family: var(--font-mono); font-size: 0.7rem; font-weight: 700; color: var(--color-accent); letter-spacing: 0.06em; display: block; margin-bottom: 0.5rem; }
  .phase-marker h2 { margin: 0; }

  .code-block { font-family: var(--font-mono); font-size: 0.875rem; background-color: var(--color-surface); border: 1px solid var(--color-border); padding: 1.25rem; margin-bottom: 1.75rem; display: flex; flex-direction: column; gap: 0.375rem; }
  .code-prompt { color: var(--color-text-muted); }
  .prompt-char { color: var(--color-text-dim); margin-right: 0.5rem; }

  .example-dialogue { border: 1px solid var(--color-border); margin: 1.75rem 0; overflow: hidden; }
  .dialogue-exchange { padding: 1rem 1.25rem; border-bottom: 1px solid var(--color-border); display: flex; gap: 1rem; align-items: flex-start; }
  .dialogue-exchange:last-child { border-bottom: none; }
  .dialogue-exchange--you { background-color: var(--color-surface); }
  .dialogue-who { font-family: var(--font-mono); font-size: 0.65rem; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase; color: var(--color-accent); flex-shrink: 0; padding-top: 0.2rem; min-width: 2.5rem; }
  .dialogue-who--you { color: var(--color-text-dim); }
  .dialogue-text { font-size: 0.9375rem !important; color: var(--color-text-muted) !important; margin: 0 !important; line-height: 1.6 !important; }

  /* Compile block */
  .compile-block { font-family: var(--font-mono); font-size: 0.8125rem; line-height: 1.6; margin-bottom: 1.75rem; display: inline-flex; flex-direction: column; background-color: var(--color-surface); border: 1px solid var(--color-border); padding: 1.25rem; }
  .compile-prompt { display: flex; align-items: center; gap: 0.5rem; margin-bottom: 1rem; }
  .prompt-cmd { color: var(--color-text-muted); }
  .compile-stages { display: flex; flex-direction: column; gap: 0.125rem; }
  .stage-row { display: grid; grid-template-columns: 2.5rem 1.25rem 1fr; align-items: center; gap: 0.5rem; }
  .stage-label { color: var(--color-text-dim); letter-spacing: 0.04em; font-size: 0.75rem; }
  .stage-check { color: var(--color-accent); }
  .stage-desc { color: var(--color-text-muted); }
  .stage-approved { color: var(--color-accent); font-weight: 500; }

  .output-block { font-family: var(--font-mono); font-size: 0.875rem; margin-bottom: 1.75rem; background-color: var(--color-surface); border: 1px solid var(--color-border); padding: 1rem 1.25rem; display: flex; flex-direction: column; gap: 0.375rem; }
  .output-row { display: grid; grid-template-columns: 8rem 1fr; gap: 1rem; }
  .output-file { color: var(--color-text); font-weight: 500; }
  .output-action { color: var(--color-text-dim); }

  .inline-code { font-family: var(--font-mono); font-size: 0.875em; color: var(--color-text-muted); }

  .link-arrow { font-size: 0.9375rem; color: var(--color-accent); display: inline-block; margin-top: 0.5rem; }
  .link-arrow:hover { text-decoration: underline; }

  .section--invite { padding: 4.5rem 0; }
  .install-block { display: inline-flex; align-items: center; gap: 0.75rem; font-family: var(--font-mono); font-size: 0.9375rem; color: var(--color-accent); margin-bottom: 1.25rem; user-select: all; }
  .install-prompt { color: var(--color-text-dim); }
  .trust-signal { font-size: 0.875rem !important; color: var(--color-text-dim) !important; margin: 0 0 2rem !important; }
  .btn-primary { font-size: 0.9375rem; font-weight: 500; color: var(--color-bg); background-color: var(--color-accent); padding: 0.7rem 1.5rem; border-radius: 3px; transition: background-color 0.12s ease; display: inline-block; }
  .btn-primary:hover { background-color: var(--color-accent-hover); color: var(--color-bg); }
</style>
