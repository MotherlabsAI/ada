---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'What is the difference between CLAUDE.md and MEMORY.md?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: "CLAUDE.md encodes your intent — what the project is, what it is not, architectural decisions, and constraints — before building starts. MEMORY.md records what Claude Code observed as it worked — retrospective notes from past sessions. CLAUDE.md is prospective: it shapes future behavior. MEMORY.md is retrospective: it captures past behavior. Ada produces CLAUDE.md from structured elicitation. You write MEMORY.md (or Claude Code auto-generates it) from session observations.",
      },
    },
    {
      '@type': 'Question',
      name: 'Can you use both CLAUDE.md and MEMORY.md?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: "Yes. They solve different problems and can coexist. CLAUDE.md (produced by Ada) encodes your intent and governs what gets built. MEMORY.md records what was observed during sessions. Ada governs. Memory records. Using both gives you prospective intent (Ada) plus retrospective continuity (memory) — covering the full context lifecycle.",
      },
    },
    {
      '@type': 'Question',
      name: 'What is Claude Code auto-memory?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: "Claude Code's auto-memory is an automatic system that records observations from sessions into MEMORY.md without requiring you to write it manually. It captures what Claude Code noticed and did. It is retrospective — it records what happened, based on what the model observed. It does not capture your original intent or the decisions you made before building started.",
      },
    },
    {
      '@type': 'Question',
      name: 'Does Ada replace MEMORY.md?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: "No. Ada and MEMORY.md operate at different points in the development lifecycle and serve different purposes. Ada formalizes intent before building starts. MEMORY.md records observations after sessions. Ada prevents drift by governing what gets built. MEMORY.md provides continuity by remembering what happened. They are complementary, not competing.",
      },
    },
  ],
};
---

<Layout
  title="CLAUDE.md vs MEMORY.md — intent vs memory in Claude Code | Motherlabs"
  description="CLAUDE.md is prospective: it governs what gets built. MEMORY.md is retrospective: it records what happened. Ada produces CLAUDE.md from structured intent before building starts."
  schemas={[faqSchema]}
>
  <Nav />

  <main>
    <section class="page-hero">
      <div class="container">
        <p class="eyebrow"><a href="/ada">Ada</a> &rarr; CLAUDE.md vs MEMORY.md</p>
        <h1>Intent vs memory.</h1>
        <p class="hero-sub">
          CLAUDE.md governs what gets built.
          MEMORY.md records what happened.
          One is prospective. One is retrospective.
          They are not the same thing.
        </p>
      </div>
    </section>

    <hr class="divider" />

    <section class="section">
      <div class="container container--prose">
        <div class="distinction-block">
          <p class="distinction-line">Claude Code's auto-memory records what it observed as it worked.</p>
          <p class="distinction-line">Ada records what you intend before it starts.</p>
          <p class="distinction-caption">One is retrospective. One is prospective. They are not the same thing.</p>
        </div>

        <p>
          Both tools exist because AI sessions have a context problem:
          each session starts fresh, and context from previous sessions doesn't automatically carry over.
          But they address this problem at different points in the lifecycle.
        </p>
      </div>
    </section>

    <hr class="divider" />

    <section class="section section--surface">
      <div class="container container--prose">
        <h2>MEMORY.md: what happened</h2>
        <p>
          MEMORY.md is a file where Claude Code (or you) records observations
          from past sessions. What was decided. What was built. What is in progress.
          Anything the AI should remember for the next session.
        </p>
        <p>
          Claude Code's auto-memory feature can write this automatically —
          recording observations without requiring manual upkeep.
        </p>
        <p>
          MEMORY.md is retrospective. It captures what the AI observed during
          sessions that have already happened. It does not capture what you intended
          before they started. If the inference was wrong from the beginning,
          MEMORY.md records the wrong inference — faithfully.
        </p>
        <div class="when-use">
          <h3>When MEMORY.md helps</h3>
          <ul>
            <li>Preserving session continuity ("I was working on X")</li>
            <li>Remembering decisions made during sessions</li>
            <li>Capturing observations about the codebase</li>
            <li>Providing context that wasn't in the original intent</li>
          </ul>
        </div>
        <div class="when-not">
          <h3>What MEMORY.md doesn't do</h3>
          <ul>
            <li>Formalize your intent before building starts</li>
            <li>Prevent drift from the original conception</li>
            <li>Encode "what this project is not"</li>
            <li>Produce structured constraints from what you said</li>
          </ul>
        </div>
      </div>
    </section>

    <hr class="divider" />

    <section class="section">
      <div class="container container--prose">
        <h2>CLAUDE.md: what you intend</h2>
        <p>
          CLAUDE.md is a file read by Claude Code on every message turn.
          It encodes the structural facts about your project: what it is,
          what it is not, what decisions have been made, what constraints apply.
        </p>
        <p>
          When produced by Ada, CLAUDE.md is not written from session observations —
          it's compiled from structured elicitation before the first session starts.
          Every constraint traces back to something you explicitly stated.
        </p>
        <p>
          CLAUDE.md is prospective. It shapes what gets built before building begins.
          It is present on every turn, constraining every decision.
        </p>
        <div class="when-use">
          <h3>When CLAUDE.md is critical</h3>
          <ul>
            <li>Encoding scope boundaries ("what this is not")</li>
            <li>Making architectural decisions persistent</li>
            <li>Constraining technology choices across sessions</li>
            <li>Defining bounded contexts and entity vocabulary</li>
            <li>Preventing Claude Code from building outside intent</li>
          </ul>
        </div>
        <div class="when-not">
          <h3>What CLAUDE.md doesn't do</h3>
          <ul>
            <li>Record what happened in past sessions</li>
            <li>Track in-progress work</li>
            <li>Replace per-task context</li>
            <li>Remember session-specific decisions</li>
          </ul>
        </div>
      </div>
    </section>

    <hr class="divider" />

    <section class="section section--surface">
      <div class="container container--prose">
        <h2>Side by side</h2>

        <div class="comparison-table">
          <div class="comparison-row comparison-row--header">
            <div class="comparison-cell"></div>
            <div class="comparison-cell">CLAUDE.md</div>
            <div class="comparison-cell">MEMORY.md</div>
          </div>
          <div class="comparison-row">
            <div class="comparison-cell comparison-cell--label">Timing</div>
            <div class="comparison-cell">Before building (prospective)</div>
            <div class="comparison-cell">After sessions (retrospective)</div>
          </div>
          <div class="comparison-row">
            <div class="comparison-cell comparison-cell--label">Written by</div>
            <div class="comparison-cell">Ada (from elicitation) or manually</div>
            <div class="comparison-cell">You, or Claude Code auto-memory</div>
          </div>
          <div class="comparison-row">
            <div class="comparison-cell comparison-cell--label">Contains</div>
            <div class="comparison-cell">Intent, constraints, decisions</div>
            <div class="comparison-cell">Observations, history, progress</div>
          </div>
          <div class="comparison-row">
            <div class="comparison-cell comparison-cell--label">When read</div>
            <div class="comparison-cell">Every message turn</div>
            <div class="comparison-cell">Every message turn (if present)</div>
          </div>
          <div class="comparison-row">
            <div class="comparison-cell comparison-cell--label">Problem solved</div>
            <div class="comparison-cell">Drift from original intent</div>
            <div class="comparison-cell">Session continuity</div>
          </div>
          <div class="comparison-row">
            <div class="comparison-cell comparison-cell--label">Fails when</div>
            <div class="comparison-cell">Written without elicitation (misses what it is not)</div>
            <div class="comparison-cell">AI's observations diverge from reality</div>
          </div>
        </div>
      </div>
    </section>

    <hr class="divider" />

    <section class="section">
      <div class="container container--prose">
        <h2>Using both</h2>
        <p>
          Ada and MEMORY.md are complementary. They cover different parts
          of the context problem.
        </p>
        <p>
          Ada governs: it encodes what you intend, structures it before building,
          and provides a persistent constraint layer. Claude Code builds against
          governed artifacts instead of informal descriptions.
        </p>
        <p>
          Memory records: it helps Claude Code remember what happened, preserving
          session continuity and capturing decisions made during the build.
        </p>
        <p>
          Together: prospective intent (Ada) plus retrospective continuity (memory).
          The full context lifecycle covered.
        </p>
        <p>
          The session pattern that works: Ada compiles intent → files land on disk →
          Claude Code reads CLAUDE.md on every turn → sessions run → memory records
          what happened → next session picks up where the last left off,
          bounded by the intent Ada wrote.
        </p>
        <a href="/ada" class="link-arrow">How Ada produces CLAUDE.md &rarr;</a>
      </div>
    </section>

    <hr class="divider" />
    <section class="section section--invite">
      <div class="container container--prose">
        <div class="install-block">
          <span class="install-prompt">$</span>
          <code class="install-cmd">npm install -g @motherlabs/ada</code>
        </div>
        <p class="trust-signal">Prospective intent. Governed artifacts. Built before Claude Code starts.</p>
        <a href="/start" class="btn-primary">Get started &rarr;</a>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<style>
  .container { max-width: 72rem; margin: 0 auto; padding: 0 clamp(1.5rem, 5vw, 4rem); }
  .container--prose { max-width: 44rem; }
  .divider { border: none; border-top: 1px solid var(--color-border); margin: 0; }

  .page-hero { padding: 4.5rem 0 3.5rem; }
  .eyebrow { font-family: var(--font-mono); font-size: 0.7rem; letter-spacing: 0.06em; color: var(--color-text-dim); margin: 0 0 1.25rem; display: block; }
  .eyebrow a { color: var(--color-accent); }
  .page-hero h1 { font-size: clamp(1.75rem, 4vw, 2.75rem); font-weight: 800; letter-spacing: -0.025em; line-height: 1.15; margin: 0 0 1.25rem; }
  .hero-sub { font-size: 1.0625rem; color: var(--color-text-muted); max-width: 38rem; margin: 0; line-height: 1.7; }

  .section { padding: 4.5rem 0; }
  .section--surface { background-color: var(--color-surface); }
  .section p { font-size: 1.0625rem; color: var(--color-text-muted); line-height: 1.8; margin: 0 0 1.25rem; }
  .section p:last-child { margin-bottom: 0; }
  .section h2 { font-size: clamp(1.375rem, 3vw, 1.875rem); font-weight: 700; color: var(--color-text); margin: 0 0 1.5rem; }

  .distinction-block { border-left: 1px solid var(--color-accent); padding-left: 1.5rem; margin-bottom: 2rem; }
  .distinction-line { font-size: 1.0625rem !important; color: var(--color-text) !important; line-height: 1.6 !important; margin: 0 0 0.625rem !important; }
  .distinction-caption { font-size: 0.9rem !important; color: var(--color-text-muted) !important; margin-top: 1rem !important; }

  .when-use, .when-not { margin-top: 1.75rem; }
  .when-use h3, .when-not h3 { font-size: 0.875rem; font-weight: 600; letter-spacing: 0.03em; margin: 0 0 0.625rem; }
  .when-use h3 { color: #4ade80; }
  .when-not h3 { color: var(--color-text-muted); }
  .when-use ul, .when-not ul { padding-left: 1.25rem; margin: 0; }
  .when-use li, .when-not li { font-size: 0.9375rem; color: var(--color-text-muted); line-height: 1.65; margin-bottom: 0.35rem; }

  .comparison-table { border: 1px solid var(--color-border); font-size: 0.9rem; }
  .comparison-row { display: grid; grid-template-columns: 9rem 1fr 1fr; border-bottom: 1px solid var(--color-border); }
  .comparison-row:last-child { border-bottom: none; }
  .comparison-row--header { background-color: var(--color-surface); }
  .comparison-row--header .comparison-cell { font-weight: 600; color: var(--color-text); font-size: 0.875rem; }
  .comparison-cell { padding: 0.875rem 1rem; color: var(--color-text-muted); border-right: 1px solid var(--color-border); line-height: 1.5; }
  .comparison-cell:last-child { border-right: none; }
  .comparison-cell--label { font-family: var(--font-mono); font-size: 0.7rem; letter-spacing: 0.04em; color: var(--color-text-dim); }
  @media (max-width: 640px) { .comparison-row { grid-template-columns: 1fr; } .comparison-row--header { display: none; } }

  .link-arrow { font-size: 0.9375rem; color: var(--color-accent); display: inline-block; margin-top: 1rem; }
  .link-arrow:hover { text-decoration: underline; }

  .section--invite { padding: 4.5rem 0; }
  .install-block { display: inline-flex; align-items: center; gap: 0.75rem; font-family: var(--font-mono); font-size: 0.9375rem; color: var(--color-accent); margin-bottom: 1.25rem; user-select: all; }
  .install-prompt { color: var(--color-text-dim); }
  .trust-signal { font-size: 0.875rem !important; color: var(--color-text-dim) !important; margin: 0 0 2rem !important; }
  .btn-primary { font-size: 0.9375rem; font-weight: 500; color: var(--color-bg); background-color: var(--color-accent); padding: 0.7rem 1.5rem; border-radius: 3px; transition: background-color 0.12s ease; display: inline-block; }
  .btn-primary:hover { background-color: var(--color-accent-hover); color: var(--color-bg); }
</style>
