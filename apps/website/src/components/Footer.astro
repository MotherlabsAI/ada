---
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="footer-inner">
    <span class="footer-copy">
      &copy; {year} Motherlabs
    </span>
    <nav class="footer-links" aria-label="Footer navigation">
      <a href="/ada">Ada</a>
      <a href="/lab">Lab</a>
      <a href="/start">Get Started</a>
      <a href="https://github.com/motherlabs" target="_blank" rel="noopener noreferrer">GitHub</a>
    </nav>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--color-border);
    margin-top: 6rem;
  }

  .footer-inner {
    max-width: 72rem;
    margin: 0 auto;
    padding: 1.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .footer-copy {
    font-size: 0.875rem;
    color: var(--color-text-muted);
  }

  .footer-links {
    display: flex;
    gap: 1.5rem;
  }

  .footer-links a {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    transition: color 0.15s;
  }

  .footer-links a:hover {
    color: var(--color-text);
  }
</style>
