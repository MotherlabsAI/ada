---
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="footer-inner">
    <div class="footer-row">
      <span class="footer-mark">Motherlabs · Vancouver</span>
      <nav class="footer-links" aria-label="Footer">
        <a href="https://github.com/motherlabs" target="_blank" rel="noopener noreferrer">GitHub</a>
        <a href="mailto:alex@motherlabs.ai">Email</a>
        <a href="/llms.txt">llms.txt</a>
      </nav>
    </div>
    <div class="footer-row footer-meta">
      <span>© {year}</span>
      <span>Research lab · not a product company</span>
    </div>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--color-border);
    margin-top: 8rem;
  }

  .footer-inner {
    max-width: 68rem;
    margin: 0 auto;
    padding: 2rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .footer-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1rem;
    font-size: 0.72rem;
    letter-spacing: 0.06em;
    color: var(--color-text-muted);
  }

  .footer-mark {
    font-family: var(--font-mono);
    text-transform: uppercase;
    letter-spacing: 0.14em;
  }

  .footer-links {
    display: flex;
    gap: 1.5rem;
  }

  .footer-links a {
    color: var(--color-text-muted);
    border: 0;
  }

  .footer-links a:hover { color: var(--color-accent); border: 0; }

  .footer-meta {
    color: var(--color-text-dim);
    font-size: 0.68rem;
  }
</style>
