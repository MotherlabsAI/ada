---
const currentPath = Astro.url.pathname;

const links = [
  { href: '/ada', label: 'Ada' },
  { href: '/lab', label: 'Lab' },
];

function isActive(href: string) {
  if (href === '/') return currentPath === '/';
  return currentPath.startsWith(href);
}
---

<header class="nav-header">
  <nav class="nav-inner">
    <a href="/" class="nav-logo" aria-label="Motherlabs home">
      <svg class="nav-logo-icon" width="20" height="20" viewBox="0 0 150 150" fill="currentColor" aria-hidden="true">
