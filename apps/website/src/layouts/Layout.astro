---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  schemas?: object[];
}

const {
  title,
  description = 'Motherlabs is a research lab building the substrate layer for the agent economy.',
  ogImage = '/og-default.png',
  schemas = [],
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? 'https://motherlabs.ai');

const orgSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Motherlabs',
  url: 'https://motherlabs.ai',
  description: 'Research lab building Motherlabs MCP — the substrate layer for the agent economy.',
  sameAs: ['https://github.com/motherlabs'],
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImage, Astro.site ?? 'https://motherlabs.ai')} />
    <meta property="og:site_name" content="Motherlabs" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, Astro.site ?? 'https://motherlabs.ai')} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />

    <script type="application/ld+json" set:html={JSON.stringify(orgSchema)} />
    {schemas.map((schema) => (
      <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    ))}
  </head>
  <body>
    <slot />
  </body>
</html>
