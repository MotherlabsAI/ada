    {
      "@id": "ada:node/LAYOUT.032",
      "@type": "ada:DesignCapsule",
      "label": "Whitespace is structural, not decorative",
      "summary": "One blank line between logical blocks, 1–2 cells padding inside any framed box, a fixed spacing rhythm held everywhere (Welcome.ts paddingX:2 / explicit gap rows). Never 0-padding (cramped), never random 1-vs-2 newline mixing.",
      "cluster": "LAYOUT",
      "truth": "source",
      "checkClass": "C2",
      "depth": "L2",
      "from": "src/tui/ink/Welcome.ts",
      "ada:whyItMatters": "Density is the absence of decorative noise, not the absence of space; rhythm is what makes a dense screen still feel calm.",
      "ada:failureIfMissing": "Inconsistent gaps make the screen feel hand-assembled and cheap, even with a perfect palette.",
      "parent": [
        "ada:node/LAYOUT.030"
      ],
      "child": [],
      "dependsOn": [],
      "sibling": [
        "ada:node/LAYOUT.033"
      ],
      "guardedBy": []
    },
    {
      "@id": "ada:node/LAYOUT.033",
      "@type": "ada:DesignCapsule",
      "label": "Frame sparingly — one border is the signature",
      "summary": "One rounded border (the Welcome box / `?` overlay) is a signature; bordering every pane is noise. Inside the workbench, separate regions with the StatusBar title and a dim hint line — no nested boxes, no second border style.",
      "cluster": "LAYOUT",
      "truth": "inference",
      "checkClass": "C2",
      "depth": "L2",
      "from": "docs/SURFACE-DESIGN.md",
      "ada:whyItMatters": "Borders are expensive attention; spending them once makes that one frame meaningful.",
      "ada:failureIfMissing": "Every pane gets a box; the screen becomes a grid of cells and the signature frame loses all weight.",
      "parent": [
        "ada:node/LAYOUT.030"
      ],
      "child": [],
      "dependsOn": [],
      "sibling": [
        "ada:node/LAYOUT.032"
      ],
