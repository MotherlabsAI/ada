    {
      "@id": "ada:node/ROOT.001",
      "@type": "ada:DesignCapsule",
      "label": "North-star: Claude Code's calm, premium sister",
      "summary": "The brief in one line: one accent on calm earth neutrals, one focal point per screen, one moving thing at a time, a frame that never jumps. Terracotta/plum is OURS — match Claude Code's restraint, never copy its hue.",
      "cluster": "ROOT",
      "truth": "source",
      "checkClass": "C1",
      "depth": "L4",
      "from": "docs/SURFACE-DESIGN.md",
      "ada:whyItMatters": "It is the single tie-breaker for every later decision; when two designs are both 'fine', the calmer one wins.",
      "ada:failureIfMissing": "The surface reads as a LangChain-clone dashboard — busy, cool-toned, generic — and the premium promise breaks on first contact.",
      "parent": [
        "ada:node/ROOT.000"
      ],
      "child": [
        "ada:node/IDENT.010",
        "ada:node/IDENT.011",
        "ada:node/LAYOUT.034",
        "ada:node/MOTION.040"
      ],
      "dependsOn": [],
