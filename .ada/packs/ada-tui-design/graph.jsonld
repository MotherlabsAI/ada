      ],
      "guardedBy": []
    },
    {
      "@id": "ada:node/ROOT.002",
      "@type": "ada:DesignCapsule",
      "label": "The paying non-technical user is the design constraint",
      "summary": "Ada's users are explicitly non-technical and pay real money (Motherlabs vision; A8). 'Premium, legible, calm' is therefore not decoration — it must hold under NO_COLOR, a screen reader, and an 80×24 terminal, or it isn't premium for everyone who paid.",
      "cluster": "ROOT",
      "truth": "source",
      "checkClass": "C1",
      "depth": "L4",
      "from": "AXIOMS.md",
      "ada:whyItMatters": "It promotes accessibility and degradation from 'nice-to-have' to a load-bearing product requirement.",
      "ada:failureIfMissing": "The surface is beautiful only on the designer's 120-col truecolor iTerm; everyone else gets a broken first impression.",
      "parent": [
        "ada:node/ROOT.000"
      ],
      "child": [
        "ada:node/FLOW.060",
        "ada:node/A11Y.080",
        "ada:node/VOICE.090"
      ],
      "dependsOn": [],
      "sibling": [
        "ada:node/ROOT.001"
      ],
      "guardedBy": []
    },
    {
      "@id": "ada:node/IDENT.010",
      "@type": "ada:DesignCapsule",
      "label": "The ADA wordmark — filled block, with fallbacks",
      "summary": "A 6-row filled-block ADA (art.ts WORDMARK) for wide terminals; a 3-row compact WORDMARK_NARROW under ~90 cols; a plain `ADA · context` line for non-TTY/piped output. Box width is computed from the longest art row, never guessed.",
      "cluster": "IDENT",
      "truth": "source",
      "checkClass": "C3",
      "depth": "L3",
      "from": "src/tui/ink/art.ts",
      "ada:whyItMatters": "The wordmark is the first frame the user sees; it must land identically across terminal widths and degrade to clean text in CI.",
      "ada:failureIfMissing": "The banner clips, mis-wraps, or spews box-drawing noise into a pipe — the first impression is broken before the product speaks.",
      "parent": [
        "ada:node/ROOT.001"
      ],
      "child": [
        "ada:node/IDENT.012",
        "ada:node/IDENT.013"
      ],
      "dependsOn": [],
      "sibling": [
        "ada:node/IDENT.011",
        "ada:node/IDENT.012",
        "ada:node/IDENT.013"
      ],
      "guardedBy": []
    },
    {
      "@id": "ada:node/IDENT.011",
      "@type": "ada:DesignCapsule",
      "label": "The eye/node mascot — animate ONE detail",
      "summary": "The default mascot is an eye (art.ts DEFAULT_MASCOT='eye') — groundable to Ada's function: a context compiler that watches your graph, not arbitrary decoration. Rows 1 and 3 are byte-identical to the blink frame; only the eye row changes (◉→═), so the silhouette is stable and flicker-free.",
      "cluster": "IDENT",
      "truth": "source",
      "checkClass": "C3",
      "depth": "L3",
      "from": "src/tui/ink/art.ts",
      "ada:whyItMatters": "Personality from a single moving detail is the cheapest, calmest way to feel 'a little alive' without violating the one-moving-thing rule.",
      "ada:failureIfMissing": "A fully animated mascot competes with the cursor and the compile heartbeat — three moving things, the opposite of calm.",
      "parent": [
        "ada:node/ROOT.001"
      ],
      "child": [],
      "dependsOn": [
        "ada:node/MOTION.040"
      ],
      "sibling": [
        "ada:node/IDENT.010"
      ],
      "guardedBy": []
    },
    {
      "@id": "ada:node/IDENT.012",
      "@type": "ada:DesignCapsule",
      "label": "Vertical terracotta→plum gradient as one object",
      "summary": "The wordmark is ramped top→bottom terracotta→clay→amber (art.ts bannerGradient, ~250ms/step triangle wave) — vertical/per-row, so the tall block reads as one coherent object. Dependency-free (~15 lines hexToRgb+lerp); no ink-gradient.",
      "cluster": "IDENT",
      "truth": "source",
      "checkClass": "C2",
      "depth": "L3",
      "from": "src/tui/ink/art.ts",
      "ada:whyItMatters": "A per-row ramp keeps the block legible as a single mark; per-character horizontal gradients look noisy and fight AESTH.005.",
      "ada:failureIfMissing": "A rainbow per-letter wordmark turns the signature mark into confetti and adds a dependency for 20 lines of owned code.",
      "parent": [
        "ada:node/IDENT.010"
      ],
      "child": [],
      "dependsOn": [
        "ada:node/PALETTE.021"
      ],
      "sibling": [
        "ada:node/IDENT.011"
      ],
      "guardedBy": []
    },
    {
      "@id": "ada:node/IDENT.013",
      "@type": "ada:DesignCapsule",
      "label": "The `context` tag as identity anchor",
      "summary": "`c o n t e x t` under the wordmark plus the subtitle 'a semantic compiler for context' (Welcome.ts) state the category in three words. It is the verbal half of the identity: the mark says ADA, the tag says what ADA is.",
      "cluster": "IDENT",
      "truth": "source",
      "checkClass": "C3",
      "depth": "L2",
      "from": "src/tui/ink/Welcome.ts",
      "ada:whyItMatters": "A non-technical user needs the category named, not inferred; the tag does that without a sentence of marketing.",
      "ada:failureIfMissing": "The user stares at a pretty ADA block with no idea what it compiles or why they should trust it.",
      "parent": [
