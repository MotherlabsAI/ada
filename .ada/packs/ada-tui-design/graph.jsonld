      ]
    },
    {
      "@id": "ada:node/MOTION.040",
      "@type": "ada:DesignCapsule",
      "label": "One clock — a single shared animation timer",
      "summary": "A single AnimationProvider at the App root owns the only timer and exposes {frame,time} via context; a spinner + a pulse + a reveal cost one timer, not three. isActive = isTTY && !NO_COLOR && (compiling||revealing||welcomeIdle); an idle Ada renders at 0fps.",
      "cluster": "MOTION",
      "truth": "inference",
      "checkClass": "C3",
      "depth": "L3",
      "from": "docs/SURFACE-DESIGN.md",
      "ada:whyItMatters": "Per-component setInterval is the #1 source of out-of-phase flicker and CPU burn; one clock is what makes motion phase-coherent and free when idle.",
      "ada:failureIfMissing": "Three timers drift out of phase, the banner and spinner stutter against each other, and a 'calm' surface jitters.",
      "parent": [
        "ada:node/ROOT.001"
      ],
      "child": [
        "ada:node/MOTION.041",
        "ada:node/MOTION.042",
