    },
    {
      "@id": "ada:node/MOTION.042",
      "@type": "ada:DesignCapsule",
      "label": "One welcome breath — border OR mascot, never both",
      "summary": "A slow breath on EITHER the banner gradient OR the mascot eye-blink — never two breathing elements at once. Welcome.ts runs the gradient ramp (~250ms) + a single eye blink (open ~3.8s/shut ~140ms); kill all of it the instant view flips to graph.",
      "cluster": "MOTION",
      "truth": "source",
      "checkClass": "C2",
      "depth": "L2",
      "from": "src/tui/ink/Welcome.ts",
      "ada:whyItMatters": "Two competing breaths read as nervousness; one slow breath reads as calm presence.",
      "ada:failureIfMissing": "Border and mascot pulse simultaneously and the home screen feels anxious instead of inviting.",
      "parent": [
        "ada:node/MOTION.040"
      ],
      "child": [],
      "dependsOn": [],
