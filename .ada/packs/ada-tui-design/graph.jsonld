    },
    {
      "@id": "ada:node/LAYOUT.034",
      "@type": "ada:DesignCapsule",
      "label": "One focal point — the cursor is the only thing fully lit",
      "summary": "One high-contrast focal point per screen. Replace the full-width inverse bar (which strobes on scroll and erases the row's area hue) with a ❯ caret + bold label + a dark desaturated area-hue background bar, so selection is unmistakable AND the area colour survives on the selected row.",
      "cluster": "LAYOUT",
      "truth": "inference",
      "checkClass": "C2",
      "depth": "L3",
      "from": "docs/SURFACE-DESIGN.md",
      "ada:whyItMatters": "A single lit focus is how the eye is led; throwing the whole row to inverse destroys the one colour you most want to read.",
      "ada:failureIfMissing": "During scroll the inverse bar strobes and the selected node loses its identity colour exactly when you're trying to identify it.",
      "parent": [
        "ada:node/ROOT.001"
      ],
      "child": [],
