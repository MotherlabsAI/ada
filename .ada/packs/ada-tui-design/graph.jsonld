    },
    {
      "@id": "ada:node/LAYOUT.031",
      "@type": "ada:DesignCapsule",
      "label": "Panes never move on their own",
      "summary": "The reader and the tree render into the IDENTICAL bodyHeight box (rows−4). Opening/closing a node deepens the same surface instead of repainting a new screen; transitions feel like focus changes, not page loads.",
      "cluster": "LAYOUT",
      "truth": "inference",
      "checkClass": "C2",
      "depth": "L3",
      "from": "docs/SURFACE-DESIGN.md",
      "ada:whyItMatters": "A surface that stays put under interaction feels solid and premium; one that repaints feels like a web page in a terminal.",
      "ada:failureIfMissing": "Following an edge swaps the whole screen; the user loses their place and their sense of where they are.",
      "parent": [
        "ada:node/LAYOUT.030"
      ],
      "child": [],
